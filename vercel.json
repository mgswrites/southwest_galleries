{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.southwestgalleries.com" }],
      "destination": "https://southwestgalleries.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*\\.svg|.*\\.jpg|.*\\.png|.*\\.webp|.*\\.ico)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
