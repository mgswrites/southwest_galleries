---
export interface Crumb {
  label: string;
  href?: string;
}
export interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, Astro.site).toString() } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="breadcrumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {c.href && i < crumbs.length - 1
          ? <a href={c.href}>{c.label}</a>
          : <span aria-current="page">{c.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<style>
  .breadcrumb { padding: 0.75rem 0; font-size: 0.85rem; color: var(--muted); }
  ol { list-style: none; display: flex; flex-wrap: wrap; gap: 0.25rem; align-items: center; }
  li + li::before { content: '/'; margin-right: 0.25rem; color: #bbb; }
  a { color: var(--muted); }
  a:hover { color: var(--turquoise); }
  span { color: var(--ink); }
</style>
