---
import Analytics from '@vercel/analytics/astro';
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
}

const {
  title,
  description = 'The definitive art and cultural directory for the American Southwest. Find galleries, museums, and cultural centers across Arizona, New Mexico, Colorado, and beyond.',
  canonical = new URL(Astro.url.pathname, Astro.site).toString(),
  ogImage = '/og-default.jpg',
  schema,
} = Astro.props;

const schemaBlocks = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Southwest Galleries" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    {schemaBlocks.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Pinyon+Script&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">Southwest Galleries</a>
        <ul>
          <li><a href="/galleries/">Galleries</a></li>
          <li><a href="/museums/">Museums</a></li>
          <li><a href="/art-styles/">Art Styles</a></li>
          <li><a href="/guides/">Guides</a></li>
          <li><a href="/events/">Events</a></li>
          <li><a href="/submit/" class="cta">Submit Listing</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <div>
          <strong>Southwest Galleries</strong>
          <p>The definitive art directory for the American Southwest.</p>
        </div>
        <div>
          <strong>Browse</strong>
          <ul>
            <li><a href="/galleries/arizona/">Arizona</a></li>
            <li><a href="/galleries/new-mexico/">New Mexico</a></li>
            <li><a href="/galleries/colorado/">Colorado</a></li>
            <li><a href="/galleries/nevada/">Nevada</a></li>
            <li><a href="/galleries/utah/">Utah</a></li>
          </ul>
        </div>
        <div>
          <strong>Discover</strong>
          <ul>
            <li><a href="/art-styles/">Art Styles</a></li>
            <li><a href="/guides/">Guides</a></li>
            <li><a href="/events/">Events</a></li>
          </ul>
        </div>
        <div>
          <strong>List Your Venue</strong>
          <ul>
            <li><a href="/submit/">Submit a Listing</a></li>
            <li><a href="/submit-event/">Submit an Event</a></li>
            <li><a href="/artists/">Southwest Artists</a></li>
          </ul>
        </div>
      </div>

      <div class="email-capture">
        <div class="email-capture-inner">
          <div class="email-capture-text">
            <strong>Stay in the Loop</strong>
            <p>New galleries, upcoming events, and Southwest art stories — delivered monthly.</p>
          </div>
          <form class="email-form" action="https://app.kit.com/forms/YOUR_FORM_ID/subscriptions" method="POST" data-sv-form="YOUR_FORM_ID" data-uid="YOUR_FORM_UID" target="_blank">
            <input type="email" name="email_address" placeholder="your@email.com" required aria-label="Email address" />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </div>

      <p class="footer-copy">&copy; {new Date().getFullYear()} SouthwestGalleries.com. All rights reserved.</p>
    </footer>
    <Analytics />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sand: #f0ebe0;
    --clay: #b85c28;
    --turquoise: #0d8c8c;
    --sage: #7a9e72;
    --ink: #1a1a14;
    --muted: #6b6e60;
    --border: #d8d2c2;
    --max-w: 1200px;
    --font-sans: system-ui, -apple-system, sans-serif;
  }

  html { font-family: var(--font-sans); color: var(--ink); background: #fff; }
  body { min-height: 100vh; display: flex; flex-direction: column; }
  main { flex: 1; }
  a { color: var(--turquoise); text-decoration: none; }
  a:hover { text-decoration: underline; }
  img { max-width: 100%; height: auto; display: block; }

  header {
    background: #fff;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  header nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .logo { font-family: 'Pinyon Script', cursive; font-weight: 400; font-size: 1.75rem; color: var(--ink); line-height: 1; }
  header nav ul { list-style: none; display: flex; gap: 1.5rem; margin-left: auto; align-items: center; }
  header nav a { color: var(--ink); font-size: 0.9rem; }
  header nav a.cta {
    background: var(--turquoise);
    color: #fff;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-weight: 600;
  }
  header nav a.cta:hover { background: #0a7070; text-decoration: none; }

  footer {
    background: var(--ink);
    color: #ccc;
    padding: 3rem 1.5rem 1.5rem;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #333;
  }
  footer strong { color: #fff; display: block; margin-bottom: 0.75rem; }
  footer ul { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  footer a { color: #aaa; font-size: 0.875rem; }
  footer a:hover { color: #fff; }
  footer p { font-size: 0.875rem; color: #888; line-height: 1.5; }
  .email-capture { border-top: 1px solid #333; padding: 2rem 0; }
  .email-capture-inner { max-width: var(--max-w); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .email-capture-text strong { color: #fff; display: block; margin-bottom: 0.3rem; }
  .email-capture-text p { font-size: 0.85rem; color: #888; margin: 0; }
  .email-form { display: flex; gap: 0.5rem; flex-shrink: 0; }
  .email-form input[type="email"] { padding: 0.55rem 0.85rem; border-radius: 5px; border: 1px solid #444; background: #2a2018; color: #fff; font-size: 0.875rem; min-width: 220px; }
  .email-form input[type="email"]::placeholder { color: #666; }
  .email-form input[type="email"]:focus { outline: 2px solid var(--turquoise); border-color: transparent; }
  .email-form button { padding: 0.55rem 1.25rem; background: var(--turquoise); color: #fff; border: none; border-radius: 5px; font-size: 0.875rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
  .email-form button:hover { background: #0a7070; }
  .footer-copy { text-align: center; margin-top: 1.5rem; font-size: 0.8rem; color: #555; max-width: var(--max-w); margin-left: auto; margin-right: auto; }

  .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }
  .page-header { background: var(--sand); padding: 3rem 1.5rem; }
  .page-header h1 { font-size: 2rem; font-weight: 700; }
  .page-header p { color: var(--muted); margin-top: 0.5rem; max-width: 600px; }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
    header nav ul { display: none; }
  }
</style>
