---
export const prerender = true;
import Base from '../layouts/Base.astro';
import ListingCard from '../components/ListingCard.astro';
import { getStates, getArtStyles, getPublishedPosts } from '../lib/queries';
import sql from '../lib/db';

const states = await getStates();
const artStyles = await getArtStyles();
const allGuides = await getPublishedPosts();
const featuredGuides = allGuides.slice(0, 4);

const [featuredGalleryRow] = await sql`
  SELECT l.slug, l.name, l.short_description, l.hero_image_url,
         c.name AS city_name, s.name AS state_name, s.slug AS state_slug
  FROM listings l
  LEFT JOIN cities c ON c.id = l.city_id
  LEFT JOIN states s ON s.code = l.state_code
  WHERE l.listing_type = 'gallery'
    AND l.status = 'approved'
    AND l.deleted_at IS NULL
    AND l.hero_image_url IS NOT NULL
    AND l.short_description IS NOT NULL
  ORDER BY RANDOM()
  LIMIT 1
`;

const [featuredArtistRow] = await sql`
  SELECT slug, name, bio, hero_image_url, state_code
  FROM artists
  WHERE hero_image_url IS NOT NULL AND bio IS NOT NULL
  ORDER BY RANDOM()
  LIMIT 1
`;
const featuredListings = await sql`
  SELECT l.id, l.slug, l.name, l.listing_type, l.tier, l.short_description,
         l.hero_image_url, l.neighborhood,
         c.name AS city_name, c.slug AS city_slug,
         s.slug AS state_slug
  FROM listings l
  LEFT JOIN cities c ON c.id = l.city_id
  LEFT JOIN states s ON s.code = l.state_code
  WHERE l.tier IN ('featured', 'premium')
    AND l.status = 'approved'
    AND l.deleted_at IS NULL
  ORDER BY CASE l.tier WHEN 'premium' THEN 1 ELSE 2 END, RANDOM()
  LIMIT 6
`;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Southwest Galleries',
  url: 'https://southwestgalleries.com',
  description: 'The definitive art and cultural directory for the American Southwest.',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Southwest Galleries',
  url: 'https://southwestgalleries.com',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://southwestgalleries.com/search/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Base
  title="Southwest Galleries: Art Galleries, Museums & Cultural Venues"
  description="The definitive directory of art galleries, museums, and cultural venues across the American Southwest. Discover art in Arizona, New Mexico, Colorado, Nevada, Utah, and beyond."
  schema={[orgSchema, websiteSchema]}
>
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <h1>Discover Art in the<br />American Southwest</h1>
      <p>The definitive directory of galleries, museums, and cultural venues across Arizona, New Mexico, Colorado, and beyond.</p>
      <div class="hero-actions">
        <a href="/galleries/" class="btn-primary">Browse Galleries</a>
        <a href="/guides/" class="btn-secondary">Read Guides</a>
      </div>
    </div>
  </section>

  <section class="editorial-section">
    <div class="container editorial-inner">
      <h2>The American Southwest: A Living Art Destination</h2>
      <div class="editorial-cols">
        <div>
          <p>The American Southwest is one of the most creatively fertile regions in the world. From the ancient Pueblo traditions of New Mexico to the cutting-edge contemporary art emerging out of Phoenix and Denver, the Southwest has always attracted artists drawn to its extraordinary light, vast landscapes, and deep cultural layers. Georgia O'Keeffe famously called northern New Mexico her spiritual home. Today, her legacy lives alongside a thriving scene of Indigenous artists, modernists, ceramicists, photographers, and sculptors who continue to redefine what Southwestern art means.</p>
          <p>Santa Fe's Canyon Road remains the most concentrated gallery district in the United States, with more than 80 galleries within a single mile. Scottsdale's arts district anchors the West's Western and contemporary fine art market. Marfa, Texas, a remote outpost in the Chihuahuan Desert, draws international visitors to the monumental installations of the Chinati Foundation and a constellation of artist-run spaces that have made the town legendary.</p>
        </div>
        <div>
          <p>Colorado adds a mountain dimension: Denver's RiNo and Santa Fe Arts District neighborhoods pulse with murals and emerging galleries, while resort towns like Aspen, Telluride, and Vail maintain world-class museum and gallery programs. Utah's redrock country frames institutions ranging from the Utah Museum of Contemporary Art in Salt Lake City to intimate pottery studios in Moab. Nevada's arts scene extends far beyond the Strip; the 18b Las Vegas Arts District and Reno's thriving creative community prove that the region's artistic identity reaches every corner of the desert West.</p>
          <p>Southwest Galleries is the definitive directory connecting art lovers, collectors, and travelers with the galleries, museums, and cultural venues that make this region extraordinary. Whether you're planning a gallery walk in Taos, a museum day in Houston, or a cross-state art road trip, start here.</p>
        </div>
      </div>
    </div>
  </section>

  {(featuredGalleryRow || featuredArtistRow) && (
    <section class="featured-pair">
      <div class="container">
        <h2 class="section-label">Featured This Month</h2>
        <div class="pair-grid">
          {featuredGalleryRow && (
            <a href={`/listing/${featuredGalleryRow.slug}/`} class="pair-card">
              <div class="pair-img" style={`background-image: url('${featuredGalleryRow.hero_image_url}')`}>
                <span class="pair-badge">Featured Gallery</span>
              </div>
              <div class="pair-body">
                <h3>{featuredGalleryRow.name}</h3>
                <p class="pair-location">{[featuredGalleryRow.city_name, featuredGalleryRow.state_name].filter(Boolean).join(', ')}</p>
                <p class="pair-desc">{featuredGalleryRow.short_description}</p>
                <span class="pair-link">Visit Gallery →</span>
              </div>
            </a>
          )}
          {featuredArtistRow && (
            <a href={`/artists/${featuredArtistRow.slug}/`} class="pair-card">
              <div class="pair-img" style={`background-image: url('${featuredArtistRow.hero_image_url}')`}>
                <span class="pair-badge">Featured Artist</span>
              </div>
              <div class="pair-body">
                <h3>{featuredArtistRow.name}</h3>
                <p class="pair-desc">{featuredArtistRow.bio?.slice(0, 160)}…</p>
                <span class="pair-link">View Artist →</span>
              </div>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="browse-states">
    <div class="container">
      <h2>Browse by State</h2>
      <div class="states-grid">
        {states.map((s) => (
          <a href={`/galleries/${s.slug}/`} class="state-card" style={`background-image: url('/states/${s.slug}.jpg')`}>
            <div class="state-card-overlay"></div>
            <div class="state-card-body">
              <span class="state-name">{s.name}</span>
              {s.gallery_count > 0 && <span class="state-count">{s.gallery_count} venues</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {featuredListings.length > 0 && (
    <section class="featured-section">
      <div class="container">
        <div class="section-header">
          <h2>Featured Galleries</h2>
          <a href="/galleries/" class="see-all">See all →</a>
        </div>
        <div class="listings-grid">
          {featuredListings.map((l) => (
            <ListingCard
              slug={l.slug} name={l.name} listing_type={l.listing_type} tier={l.tier}
              short_description={l.short_description} hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood} city_name={l.city_name} city_slug={l.city_slug}
              state_slug={l.state_slug}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {featuredGuides.length > 0 && (
    <section class="guides-section">
      <div class="container">
        <div class="section-header">
          <h2>Southwest Art Guides</h2>
          <a href="/guides/" class="see-all">All guides →</a>
        </div>
        <div class="guides-grid">
          {featuredGuides.map((g) => (
            <a href={`/guides/${g.slug}/`} class="guide-card">
              {g.hero_image_url && (
                <img src={g.hero_image_url} alt={g.title} loading="lazy" width="400" height="225" />
              )}
              <div class="guide-body">
                <h3>{g.title}</h3>
                {g.excerpt && <p>{g.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="cta-section">
    <div class="container cta-inner">
      <div>
        <h2>Own a gallery or museum?</h2>
        <p>Get your venue in front of thousands of art lovers and collectors.</p>
      </div>
      <a href="/submit/" class="btn-primary">Submit Your Listing</a>
    </div>
  </section>

  <section class="browse-styles">
    <div class="container">
      <h2>Browse by Art Style</h2>
      <div class="styles-grid">
        {artStyles.map((s) => (
          <a href={`/art-styles/${s.slug}/`} class="style-card" style={`background-image: url('/art-styles/${s.slug}.jpg')`}>
            <div class="style-card-overlay"></div>
            <div class="style-card-body">
              <span class="style-name">{s.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: center 95%;
    color: #fff;
    padding: 6rem 0;
    min-height: 620px;
    display: flex;
    align-items: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15, 8, 4, 0.80) 0%,
      rgba(15, 8, 4, 0.55) 50%,
      rgba(15, 8, 4, 0.10) 100%
    );
  }
  .hero-inner {
    position: relative;
    max-width: 560px;
    margin-left: 5%;
  }
  .hero h1 { font-family: 'Rye', serif; font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 400; line-height: 1.18; margin-bottom: 1.1rem; letter-spacing: 0.01em; }
  .hero p { font-size: 1.1rem; color: rgba(255,255,255,0.88); margin-bottom: 2rem; line-height: 1.65; max-width: 460px; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { background: var(--turquoise); color: #fff; padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 700; font-size: 1rem; text-decoration: none; }
  .btn-primary:hover { background: #0a7070; text-decoration: none; }
  .btn-secondary { background: #b8860b; color: #fff; padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 600; font-size: 1rem; text-decoration: none; border: none; }
  .btn-secondary:hover { background: #9a6f09; text-decoration: none; }

  .featured-pair { padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .section-label { font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 1.25rem; }
  .pair-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .pair-card { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; transition: box-shadow 0.2s, transform 0.2s; display: flex; flex-direction: column; }
  .pair-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.12); transform: translateY(-3px); text-decoration: none; }
  .pair-img { position: relative; height: 260px; background-size: cover; background-position: center; background-color: var(--sand); flex-shrink: 0; }
  .pair-badge { position: absolute; top: 1rem; left: 1rem; background: rgba(0,0,0,0.55); color: #fff; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.3rem 0.7rem; border-radius: 20px; backdrop-filter: blur(6px); }
  .pair-body { padding: 1.25rem 1.5rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .pair-body h3 { font-size: 1.15rem; font-weight: 700; line-height: 1.3; }
  .pair-location { font-size: 0.8rem; color: var(--muted); }
  .pair-desc { font-size: 0.875rem; color: #555; line-height: 1.6; flex: 1; }
  .pair-link { font-size: 0.85rem; font-weight: 700; color: var(--turquoise); margin-top: 0.25rem; }

  @media (max-width: 680px) { .pair-grid { grid-template-columns: 1fr; } .pair-img { height: 200px; } }

  .browse-states { background: var(--sand); padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .browse-states h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); }
  .states-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.75rem; }
  .state-card {
    position: relative;
    display: block;
    height: 160px;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    background-size: cover;
    background-position: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .state-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.18); text-decoration: none; }
  .state-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.18) 60%, rgba(0,0,0,0.05) 100%);
  }
  .state-card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .state-name { color: #fff; font-size: 0.9rem; font-weight: 700; line-height: 1.2; }
  .state-count { color: rgba(255,255,255,0.75); font-size: 0.72rem; font-weight: 500; }

  @media (max-width: 900px) { .states-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 560px) { .states-grid { grid-template-columns: repeat(2, 1fr); } }

  .featured-section { padding: 3rem 0; }
  .section-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.25rem; }
  .section-header h2 { font-size: 1.4rem; font-weight: 700; }
  .see-all { font-size: 0.875rem; color: var(--turquoise); text-decoration: none; font-weight: 600; }
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }

  .guides-section { padding: 3rem 0; border-top: 1px solid var(--border); }
  .guides-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
  .guide-card { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; text-decoration: none; color: inherit; transition: box-shadow 0.2s, transform 0.2s; display: flex; flex-direction: column; }
  .guide-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .guide-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
  .guide-body { padding: 1rem 1.25rem 1.25rem; flex: 1; }
  .guide-body h3 { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 700; line-height: 1.4; margin-bottom: 0.4rem; }
  .guide-body p { font-size: 0.8rem; color: var(--muted); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  .editorial-section { background: var(--sand); padding: 3.5rem 0; border-top: 1px solid var(--border); }
  .editorial-inner h2 { font-size: 1.5rem; margin-bottom: 1.5rem; }
  .editorial-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  .editorial-cols p { font-size: 0.925rem; color: #444; line-height: 1.75; margin-bottom: 1rem; }
  .editorial-cols p:last-child { margin-bottom: 0; }
  @media (max-width: 680px) { .editorial-cols { grid-template-columns: 1fr; } }

  .cta-section { background: var(--ink); color: #fff; padding: 3rem 0; }
  .cta-inner { display: flex; justify-content: space-between; align-items: center; gap: 2rem; flex-wrap: wrap; }
  .cta-inner h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.35rem; }
  .cta-inner p { color: #aaa; font-size: 0.95rem; }

  .browse-styles { background: var(--sand); padding: 3rem 0; border-top: 1px solid var(--border); }
  .browse-styles h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); }
  .styles-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.75rem; }
  .style-card {
    position: relative;
    display: block;
    height: 160px;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    background-size: cover;
    background-position: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .style-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.18); text-decoration: none; }
  .style-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.18) 60%, rgba(0,0,0,0.05) 100%);
  }
  .style-card-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem;
  }
  .style-name { color: #fff; font-size: 0.85rem; font-weight: 700; line-height: 1.2; }

  @media (max-width: 900px) { .styles-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 560px) { .styles-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
