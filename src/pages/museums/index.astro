---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getStates } from '../../lib/queries';
import sql from '../../lib/db';

const states = await getStates();

const museumCounts = await sql`
  SELECT state_code, COUNT(*) AS count
  FROM listings
  WHERE listing_type IN ('museum', 'cultural_center', 'sculpture_park')
    AND status = 'approved'
    AND deleted_at IS NULL
  GROUP BY state_code
`;

const countByState = Object.fromEntries(
  museumCounts.map((r) => [r.state_code, Number(r.count)])
);

const title = 'Museums & Cultural Centers in the Southwest | Southwest Galleries';
const description = 'Explore museums, cultural centers, and sculpture parks across the American Southwest: Arizona, New Mexico, Colorado, Nevada, Utah, and beyond.';
---

<Base {title} {description}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'Museums' }]} />
      <h1>Museums &amp; Cultural Centers</h1>
      <p>Explore museums, cultural centers, and sculpture parks across the American Southwest.</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    <div class="states-grid">
      {states.map((state) => {
        const count = countByState[state.code] ?? 0;
        return (
          <a href={`/museums/${state.slug}/`} class="state-card">
            <div class="state-img" style={`background-image: url('/states/${state.slug}.jpg')`}>
              <div class="state-img-overlay"></div>
            </div>
            <div class="state-info">
              <h2>{state.name}</h2>
              <p>{count > 0 ? `${count} venue${count !== 1 ? 's' : ''}` : 'Coming soon'}</p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Base>

<style>
  .states-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .state-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .state-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.12); transform: translateY(-2px); text-decoration: none; }
  .state-img {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background-size: cover;
    background-position: center;
    background-color: var(--sand);
  }
  .state-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.25) 100%);
  }
  .state-info { padding: 1rem 1.1rem; }
  .state-info h2 { font-size: 1.1rem; font-weight: 700; }
  .state-info p { font-size: 0.875rem; color: var(--muted); margin-top: 0.25rem; }

  @media (max-width: 600px) { .states-grid { grid-template-columns: 1fr 1fr; } }
</style>
