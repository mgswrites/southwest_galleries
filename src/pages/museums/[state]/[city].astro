---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import BreadcrumbNav from '../../../components/BreadcrumbNav.astro';
import ListingCard from '../../../components/ListingCard.astro';
import { getStates, getState, getCitiesByState, getCity } from '../../../lib/queries';
import sql from '../../../lib/db';

export async function getStaticPaths() {
  const states = await getStates();
  const paths = [];
  for (const s of states) {
    const cities = await getCitiesByState(s.code);
    for (const c of cities) {
      paths.push({ params: { state: s.slug, city: c.slug } });
    }
  }
  return paths;
}

const { state: stateSlug, city: citySlug } = Astro.params;
const stateData = await getState(stateSlug!);
if (!stateData) return Astro.redirect('/');
const cityData = await getCity(stateData.code, citySlug!);
if (!cityData) return Astro.redirect(`/museums/${stateSlug}/`);

const listings = await sql`
  SELECT id, slug, name, listing_type, tier, short_description, hero_image_url, neighborhood, address_line1
  FROM listings
  WHERE city_id = ${cityData.id}
    AND listing_type IN ('museum', 'cultural_center', 'sculpture_park')
    AND status = 'approved'
    AND deleted_at IS NULL
  ORDER BY CASE tier WHEN 'premium' THEN 1 WHEN 'featured' THEN 2 WHEN 'basic' THEN 3 ELSE 4 END, name
`;

const title = `Museums in ${cityData.name}, ${stateData.name} | Southwest Galleries`;
const description = `Discover museums, cultural centers, and sculpture parks in ${cityData.name}, ${stateData.name}. Browse ${listings.length} venue${listings.length === 1 ? '' : 's'} with hours, locations, and details.`;
const topNames = (listings as any[]).slice(0, 3).map((l) => l.name as string);

const bookingSearchUrl = `https://www.booking.com/searchresults.en-us.html?ss=${encodeURIComponent(cityData.name + ', ' + stateData.name)}`;
const bookingLink = `https://www.anrdoezrs.net/click-101807255-17293132?url=${encodeURIComponent(bookingSearchUrl)}`;

const cityMuseumEditorials: Record<string, { intro: string; deepDiveHeading: string; deepDive: string }> = {
  'new-mexico/santa-fe': {
    intro: "Santa Fe's Museum Hill is one of the great cultural concentrations in the American Southwest, four world-class institutions within easy walking distance of each other, spanning folk art, Indigenous art, natural history, and Spanish colonial heritage.",
    deepDiveHeading: "Planning Your Museum Hill Visit",
    deepDive: "The New Mexico Museum of Art, housed in a 1917 Spanish Colonial Revival building on the Plaza, anchors Santa Fe's institutional art scene with rotating exhibitions and a permanent collection emphasizing New Mexico's own artistic tradition. A short walk brings you to Museum Hill, where four institutions cluster together: the Museum of International Folk Art holds the largest collection of folk art in the world, with more than 130,000 objects spanning every inhabited continent. The Museum of Indian Arts and Culture presents the arts and cultures of the Southwest's Indigenous peoples, Pueblo, Diné, Apache, and more, with depth and respect. The Wheelwright Museum of the American Indian focuses on Diné art and weaving, while the Museum of Spanish Colonial Art documents the centuries of Hispanic artistic tradition in New Mexico. The Georgia O'Keeffe Museum on Johnson Street draws visitors from around the world to the work of the artist most identified with this landscape. Between Museum Hill and the Plaza, Santa Fe offers more museum-quality art per square mile than almost any city its size in the country.",
  },
  'new-mexico/albuquerque': {
    intro: "Albuquerque's museum landscape spans Indigenous culture, New Mexico history, and contemporary art, anchored by a cluster of institutions in Old Town and the University of New Mexico campus area.",
    deepDiveHeading: "Albuquerque's Cultural Institutions",
    deepDive: "The Albuquerque Museum in Old Town covers New Mexico history and fine art across four centuries, with particular strength in Spanish colonial work and twentieth-century New Mexico painting. The New Mexico Museum of Natural History and Science, also in Old Town, provides essential geological and paleontological context for understanding the landscape that defines so much of the region's art. The University of New Mexico Art Museum on the main campus holds a significant collection of prints, photographs, and paintings, and the Maxwell Museum of Anthropology offers one of the strongest collections of Southwest Indigenous material culture in the state. The Indian Pueblo Cultural Center, operated by the nineteen Pueblos of New Mexico, presents Pueblo history and contemporary art with an authority that no outside institution can match. Together these institutions make Albuquerque an underrated museum destination, one that rewards visitors willing to move beyond the most famous Santa Fe institutions.",
  },
  'arizona/phoenix': {
    intro: "Phoenix is home to the Phoenix Art Museum, the largest visual arts institution in the American Southwest, alongside the Heard Museum, internationally recognized for its Indigenous art and culture collections.",
    deepDiveHeading: "Phoenix's World-Class Museum Scene",
    deepDive: "The Phoenix Art Museum houses more than 20,000 works spanning fashion, Western American art, Latin American painting, Asian decorative arts, and photography, with a particularly strong collection of American art and rotating blockbuster exhibitions that rival those of major coastal institutions. The Heard Museum, founded in 1929, holds one of the finest collections of Indigenous art in the world, with particular depth in Diné weaving, Hopi kachina carvings, and contemporary Indigenous painting and sculpture. The Heard's annual Indigenous arts market is among the most significant in the nation. The Musical Instrument Museum, though not an art museum in the traditional sense, holds a collection of global visual culture that any serious museum visitor should not miss. The Desert Botanical Garden and the Phoenix Zoo extend the cultural landscape into the natural world. For a city its size, Phoenix punches well above its weight in museum culture.",
  },
  'arizona/scottsdale': {
    intro: "Scottsdale's cultural institutions range from the landmark Scottsdale Museum of Contemporary Art to the Western Spirit Museum, making it one of the most museum-rich mid-size cities in the Southwest.",
    deepDiveHeading: "Scottsdale's Cultural Landscape",
    deepDive: "The Scottsdale Museum of Contemporary Art (SMoCA) presents cutting-edge work in a striking building by Will Bruder that is itself a piece of contemporary architecture worth experiencing. The Western Spirit: Scottsdale's Museum of the West celebrates the cultures, histories, and arts of nineteen Western states with an impressive permanent collection and rotating exhibitions. The Scottsdale Historical Museum documents the city's development from agricultural settlement to arts destination. The Heard Museum's Scottsdale branch extends the Phoenix flagship's Indigenous art programming to the East Valley. And the city's gallery district in Old Town Scottsdale, with its Thursday evening ArtWalk, functions as a kind of living museum for collectors, making Scottsdale one of the most active commercial art markets in the United States. The combination of institutional depth and commercial vitality gives the city a cultural weight that surprises many first-time visitors.",
  },
  'arizona/tucson': {
    intro: "Tucson's museum landscape reflects the city's position at the intersection of Sonoran Desert ecology, Indigenous culture, and the deep history of the U.S.-Mexico borderlands.",
    deepDiveHeading: "Tucson's Cultural Institutions",
    deepDive: "The University of Arizona Museum of Art holds a distinguished collection spanning European old masters, American modernism, and Latin American work, with rotating exhibitions that bring major loans to campus. The Arizona State Museum, also on the UA campus, is the oldest and largest anthropology museum in the Southwest, with extraordinary collections of Indigenous material culture from throughout the region. The Tucson Museum of Art in downtown focuses on pre-Columbian art, historic and contemporary American West art, and Latino art, with a campus that includes several historic adobe structures. The Arizona-Sonora Desert Museum, technically a zoo, botanical garden, and natural history museum combined, provides indispensable ecological context for understanding the landscape that drives so much Southwest visual culture. These institutions, combined with a vibrant alternative art scene, make Tucson one of the most culturally rich smaller cities in the Southwest.",
  },
  'arizona/sedona': {
    intro: "Sedona's cultural offerings are smaller in scale than its major Arizona counterparts but remarkable for their setting, institutions embedded in one of the most visually dramatic landscapes in the world.",
    deepDiveHeading: "Art and Culture in Red Rock Country",
    deepDive: "The Sedona Arts Center is the oldest arts organization in the Verde Valley, presenting exhibitions, classes, and community programs in a setting defined by the famous red rock formations that surround the city. The Tlaquepaque Arts and Shopping Village, modeled on a traditional Mexican village, houses galleries and studios within a beautiful open-air complex that functions as both a commercial and cultural space. The Sedona Heritage Museum preserves the history of early settlement in the Verde Valley. What Sedona offers that no institution can replicate, however, is the landscape itself: the ability to stand in the presence of Cathedral Rock or Bell Rock and understand, viscerally, why artists have been traveling here for over a century to paint and sculpt and photograph. Gallery-hopping in Sedona is inseparable from the experience of the land.",
  },
  'colorado/denver': {
    intro: "Denver's museum scene is anchored by the Denver Art Museum, one of the great encyclopedic art museums in the American West, alongside a constellation of strong institutions in the Golden Triangle neighborhood.",
    deepDiveHeading: "Denver's Museum District",
    deepDive: "The Denver Art Museum holds one of the finest collections of Indigenous art in the nation alongside strong holdings in European, American, Asian, and pre-Columbian art. Its Frederic C. Hamilton Building, designed by Daniel Libeskind, is a landmark of contemporary architecture. The adjacent Clyfford Still Museum houses the most comprehensive collection of work by a single Abstract Expressionist painter in the world, a destination for serious students of postwar American art. The History Colorado Center preserves the state's frontier, mining, and Indigenous history with engaging interactive exhibitions. The Kirkland Museum of Fine & Decorative Art holds an extraordinary collection of Colorado modernism alongside international decorative arts. The McNichols Civic Center Building functions as a flexible arts venue. Together these institutions, concentrated in the Golden Triangle neighborhood, constitute one of the strongest cultural districts in the Mountain West.",
  },
  'colorado/boulder': {
    intro: "Boulder's cultural institutions reflect the city's university character and outdoor orientation, with the University of Colorado Art Museum at the center of a lively arts and culture scene.",
    deepDiveHeading: "Boulder's Arts and Museum Scene",
    deepDive: "The University of Colorado Art Museum holds a significant collection of works on paper, photography, and contemporary art, with a particular commitment to experimental and socially engaged practice. The CU Heritage Center documents the university's history and its role in showing Colorado. The Boulder Museum of Contemporary Art (BMoCA) presents ambitious exhibitions of contemporary work in an intimate downtown space, consistently punching above its institutional weight. The Leanin' Tree Museum of Western Art holds one of the largest privately owned collections of contemporary Western art in the country, a surprising destination for collectors of traditional and representational Western painting and sculpture. Boulder's combination of academic rigor, progressive cultural politics, and proximity to the natural world gives its museum scene a distinctive intellectual character.",
  },
  'colorado/aspen': {
    intro: "The Aspen Art Museum is one of the most architecturally celebrated contemporary art institutions in the Mountain West, presenting exhibitions of international significance in a setting of extraordinary natural beauty.",
    deepDiveHeading: "Contemporary Art at Altitude",
    deepDive: "The Aspen Art Museum, housed in a landmark woven-facade building designed by Shigeru Ban and opened in 2014, presents a year-round program of contemporary art exhibitions at the highest institutional level. The museum does not maintain a permanent collection, instead devoting all its resources to rotating shows of work by artists of international stature, a programming model that gives it unusual flexibility and keeps its offerings fresh for the repeat visitors that Aspen's resort economy generates. Entry is free to the public, an unusual policy that reflects the museum's commitment to broad access even in one of America's wealthiest resort communities. The rooftop restaurant offers some of the most dramatic mountain views in the Rockies. For visitors expecting an alpine resort arts scene, the Aspen Art Museum consistently exceeds expectations, it is a serious institution doing serious work.",
  },
  'nevada/las-vegas': {
    intro: "Las Vegas has developed a surprisingly robust cultural infrastructure beneath its entertainment reputation, anchored by the Nevada Museum of Art in Reno and growing institutions in the downtown Las Vegas Arts District.",
    deepDiveHeading: "Art Beyond the Strip",
    deepDive: "The Bellagio Gallery of Fine Art presents rotating exhibitions of works from major private collections and international museums in an intimate gallery space inside the Bellagio resort, a remarkable example of fine art finding its way into one of the world's most unexpected contexts. The Las Vegas Natural History Museum and the Nevada State Museum provide historical and natural context for understanding the desert landscape. The Mob Museum, technically the National Museum of Organized Crime and Law Enforcement, is one of the most visited museums in the city, its subject matter inseparable from Las Vegas's own history. The downtown Las Vegas Arts District, centered around Charleston Boulevard, hosts galleries, studios, and the monthly First Friday arts walk that has driven the neighborhood's cultural development. The Smith Center for the Performing Arts has anchored a genuine downtown cultural revival. And the Neon Museum preserves the iconic signage that made Las Vegas's visual culture, understanding it as art, not merely nostalgia.",
  },
  'utah/salt-lake-city': {
    intro: "Salt Lake City's cultural institutions reflect the city's dual identity as the center of Mormon heritage and as an increasingly cosmopolitan Western capital, with strong university and fine arts institutions.",
    deepDiveHeading: "Salt Lake City's Museum Landscape",
    deepDive: "The Utah Museum of Fine Arts on the University of Utah campus holds the most comprehensive art collection in the state, spanning ancient through contemporary work with particular strength in European and American painting. The Natural History Museum of Utah, housed in a striking building by GSBS Architects, presents the geology, paleontology, and Indigenous cultural heritage of Utah with world-class scientific depth and design. The Church History Museum explores the history of the Church of Jesus Christ of Latter-day Saints, an institution whose cultural influence on Utah is impossible to overstate. The Utah Museum of Contemporary Art downtown presents more experimental programming in a flexible urban space. Pioneer Memorial Museum documents the pioneer heritage of the Mormon settlement. Together these institutions give Salt Lake City a cultural infrastructure that belies its relatively modest size, and the city's compact geography makes visiting multiple institutions in a single day straightforward.",
  },
  'texas/houston': {
    intro: "Houston's museum district is one of the finest in the country, anchoring a city that has invested in cultural institutions with remarkable consistency and ambition.",
    deepDiveHeading: "Houston's World-Class Museum District",
    deepDive: "The Museum of Fine Arts, Houston holds one of the largest art collections in the United States, with particular strength in European painting, Latin American art, and photography. The Menil Collection, housed in a Renzo Piano building of legendary beauty in a quiet residential neighborhood, presents one of the world's great private collections of Surrealism, tribal art, and Byzantine and medieval work, free to the public. The Contemporary Arts Museum Houston presents challenging contemporary work in a signature metallic building by Günter Behnisch. The Rothko Chapel, containing fourteen paintings by Mark Rothko in a non-denominational meditative space, is one of the most moving art experiences available anywhere in the world. The Holocaust Museum Houston, the Children's Museum of Houston, and the Museum of Natural Science round out a district that makes Houston, often overlooked by visitors focused on New York and Los Angeles, one of the most impressive museum cities in the United States.",
  },
  'texas/dallas': {
    intro: "Dallas has one of the strongest concentrations of major art museums in Texas, anchored by the Dallas Museum of Art and the Nasher Sculpture Center in the downtown Arts District.",
    deepDiveHeading: "The Dallas Arts District",
    deepDive: "The Dallas Museum of Art holds a strong encyclopedic collection with particular depth in pre-Columbian, African, and American art, and offers free general admission to its permanent collection. The Nasher Sculpture Center, designed by Renzo Piano, houses one of the world's great collections of modern and contemporary sculpture in an indoor-outdoor environment of extraordinary quality. The Crow Museum of Asian Art presents one of the finest collections of Asian decorative arts and sculpture in the Southwest. The Perot Museum of Nature and Science and the Sixth Floor Museum at Dealey Plaza, dedicated to the Kennedy assassination, round out a cultural district that is among the most ambitious and visitor-friendly in the American South and Southwest. The Dallas Arts District, concentrated in the eastern edge of downtown, constitutes one of the largest urban arts districts in the country by acreage.",
  },
  'texas/san-antonio': {
    intro: "San Antonio's museum scene reflects the city's extraordinary cultural richness, Spanish colonial history, Indigenous heritage, Mexican American culture, and contemporary Texas art all find strong institutional homes here.",
    deepDiveHeading: "San Antonio's Cultural Depth",
    deepDive: "The San Antonio Museum of Art occupies a beautifully converted Lone Star Brewery building and holds one of the finest collections of Latin American art in the United States, alongside strong holdings in ancient Mediterranean, American, and Asian art. The McNay Art Museum, housed in a stunning Spanish Colonial Revival mansion on the city's north side, was the first museum of modern art in Texas and holds an exceptional collection of European and American modernism alongside a superb theater arts archive. The Witte Museum covers Texas natural and cultural history with particular attention to Southwest Indigenous cultures and the Hill Country ecosystem. The San Antonio Missions National Historical Park, a UNESCO World Heritage Site, preserves the Spanish colonial mission system that shaped the entire region. Mission San Juan, Mission Concepción, and Mission San José are among the most significant cultural monuments in the American Southwest.",
  },
  'texas/marfa': {
    intro: "Marfa's cultural institutions are few but internationally significant, anchored by the Chinati Foundation, Donald Judd's permanent large-scale installation is one of the most important works of site-specific art in the world.",
    deepDiveHeading: "Marfa's Art World Significance",
    deepDive: "The Chinati Foundation, established by Donald Judd in 1986 in a former U.S. Army fort on the outskirts of Marfa, presents Judd's permanent large-scale installations of aluminum and concrete alongside works by John Chamberlain, Dan Flavin, Ilya Kabakov, and other artists commissioned specifically for the site. The experience of walking through Judd's one hundred untitled works in mill aluminum, arranged in two long artillery sheds on the West Texas plains, is one of the defining art experiences available anywhere in the world. The Judd Foundation preserves Judd's personal spaces in Marfa and his archive of writings and design work. The Ballroom Marfa presents contemporary art, performance, and music in a converted dance hall, extending the town's cultural programming beyond Chinati. The combination of extreme landscape, institutional ambition, and intimate scale gives Marfa a cultural atmosphere unlike any other art destination in the Southwest.",
  },
  'texas/austin': {
    intro: "Austin's museum scene has grown significantly with the city itself, anchored by the Blanton Museum of Art on the UT campus and a lively alternative art ecosystem across the city.",
    deepDiveHeading: "Austin's Cultural Landscape",
    deepDive: "The Blanton Museum of Art at the University of Texas holds the largest university art collection in the American South and Southwest, with particular strength in modern and contemporary Latin American art and European paintings. The Blanton also presents major temporary exhibitions and has invested in public art on campus, including Ellsworth Kelly's permanent chapel-like installation 'Austin.' The Austin Museum of Art focuses on American art and regional Texas work. The Harry Ransom Center, also at UT, holds one of the greatest research libraries of literature, photography, and cultural history in the country, including one of the oldest photographs ever made. The South Congress and East Austin gallery scenes represent Austin's vibrant alternative art ecosystem, where independent galleries, artist studios, and project spaces have thrived alongside the city's explosive growth.",
  },
};

const cityKey = `${stateSlug}/${citySlug}`;
const cityEditorial = cityMuseumEditorials[cityKey];
---

<Base {title} {description} noindex={listings.length === 0}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: stateData.name, href: `/galleries/${stateSlug}/` },
        { label: 'Museums', href: `/museums/${stateSlug}/` },
        { label: cityData.name },
      ]} />
      <h1>Museums in {cityData.name}</h1>
      <p>
        {cityEditorial ? cityEditorial.intro : (
          <>
            {cityData.name} has {listings.length} {listings.length === 1 ? 'museum, cultural center, or sculpture park' : 'museums, cultural centers, and sculpture parks'} in {stateData.name}.
            {topNames.length > 0 && ` Highlights include ${topNames.join(', ')}${listings.length > 3 ? ', and more' : ''}.`}
            {' '}Browse below for hours, locations, and visitor information.
          </>
        )}
      </p>
    </div>
  </div>
  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    <div class="listings-grid">
      {listings.map((l) => (
        <ListingCard slug={l.slug} name={l.name} listing_type={l.listing_type} tier={l.tier}
          short_description={l.short_description} hero_image_url={l.hero_image_url}
          neighborhood={l.neighborhood} city_name={cityData.name} />
      ))}
    </div>
    {listings.length === 0 && (
      <p style="color:var(--muted);text-align:center;padding:3rem">No museum listings yet. <a href="/submit/">Submit one →</a></p>
    )}
    <section class="hotel-cta">
      <div class="hotel-cta-inner">
        <div class="hotel-cta-text">
          <h2>Where to Stay in {cityData.name}</h2>
          <p>Find hotels, inns, and vacation rentals near {cityData.name}'s museums and cultural venues.</p>
        </div>
        <div>
          <a href={bookingLink} target="_blank" rel="noopener noreferrer sponsored" class="hotel-cta-btn">
            Search Hotels on Booking.com →
          </a>
          <p class="hotel-disclosure">Affiliate link, we may earn a commission at no cost to you.</p>
        </div>
      </div>
    </section>
    {cityEditorial && (
      <section class="deep-dive">
        <h2>{cityEditorial.deepDiveHeading}</h2>
        <p>{cityEditorial.deepDive}</p>
        {citySlug === 'albuquerque' && (
          <div class="amazon-book-cta">
            <div class="amazon-book-inner">
              <div>
                <p class="amazon-book-label">Recommended Reading</p>
                <p class="amazon-book-text">Explore Albuquerque's rich art history through the Albuquerque Museum's permanent collection, spanning four centuries of New Mexico culture.</p>
              </div>
              <a href="https://amzn.to/4f5Rlc6" target="_blank" rel="noopener noreferrer sponsored" class="amazon-book-btn">View on Amazon →</a>
            </div>
            <p class="amazon-disclosure">As an Amazon Associate, we earn from qualifying purchases.</p>
          </div>
        )}
        {citySlug === 'santa-fe' && (
          <>
            <div class="amazon-book-cta">
              <div class="amazon-book-inner">
                <div>
                  <p class="amazon-book-label">Recommended Reading</p>
                  <p class="amazon-book-text">Explore Georgia O'Keeffe's paintings, her life in the high desert, and her enduring legacy in northern New Mexico.</p>
                </div>
                <a href="https://amzn.to/3QHc1hk" target="_blank" rel="noopener noreferrer sponsored" class="amazon-book-btn">View on Amazon →</a>
              </div>
              <p class="amazon-disclosure">As an Amazon Associate, we earn from qualifying purchases.</p>
            </div>
            <div class="amazon-book-cta">
              <div class="amazon-book-inner">
                <div>
                  <p class="amazon-book-label">Recommended Reading</p>
                  <p class="amazon-book-text">A visual guide to Santa Fe's art and architecture, from its historic adobe buildings to the galleries and cultural institutions that define the city.</p>
                </div>
                <a href="https://amzn.to/3SzCePp" target="_blank" rel="noopener noreferrer sponsored" class="amazon-book-btn">View on Amazon →</a>
              </div>
              <p class="amazon-disclosure">As an Amazon Associate, we earn from qualifying purchases.</p>
            </div>
          </>
        )}
      </section>
    )}
  </div>
</Base>

<style>
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .deep-dive { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); max-width: 800px; }
  .deep-dive h2 { font-size: 1.4rem; margin-bottom: 1rem; color: var(--ink); }
  .deep-dive p { color: #444; line-height: 1.75; }
  .amazon-book-cta { margin-top: 1.75rem; padding: 1.25rem 1.5rem; background: #fdf8f4; border: 1px solid var(--border); border-left: 4px solid var(--clay); border-radius: 6px; }
  .amazon-book-inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .amazon-book-label { font-size: 0.7rem !important; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--clay) !important; margin-bottom: 0.3rem; line-height: 1.2 !important; }
  .amazon-book-text { font-size: 0.9rem !important; line-height: 1.5 !important; color: var(--ink) !important; margin: 0; }
  .amazon-book-btn { flex-shrink: 0; display: inline-block; background: var(--clay); color: #fff; padding: 0.65rem 1.25rem; border-radius: 6px; font-weight: 700; font-size: 0.875rem; text-decoration: none; white-space: nowrap; }
  .amazon-book-btn:hover { opacity: 0.88; text-decoration: none; }
  .amazon-disclosure { font-size: 0.7rem !important; color: #999 !important; margin-top: 0.75rem; margin-bottom: 0; line-height: 1.4 !important; }
  .hotel-cta { margin-top: 3rem; background: var(--surface); border-radius: 10px; padding: 1.75rem 2rem; }
  .hotel-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .hotel-cta-text h2 { font-size: 1.2rem; font-weight: 700; color: var(--sand); margin-bottom: 0.35rem; }
  .hotel-cta-text p { font-size: 0.9rem; color: var(--surface-muted); margin: 0; line-height: 1.5; }
  .hotel-cta-btn { display: inline-block; background: #003580; color: #fff; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
  .hotel-cta-btn:hover { background: #002a6b; text-decoration: none; }
  .hotel-disclosure { font-size: 0.7rem; color: rgba(255,255,255,0.65); margin-top: 0.5rem; text-align: center; }
</style>
