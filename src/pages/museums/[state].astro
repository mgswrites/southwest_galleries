---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getStates, getState, getCitiesByState } from '../../lib/queries';
import sql from '../../lib/db';

export async function getStaticPaths() {
  const states = await getStates();
  return states.map((s) => ({ params: { state: s.slug } }));
}

const { state: stateSlug } = Astro.params;
const stateData = await getState(stateSlug!);
if (!stateData) return Astro.redirect('/');

const cities = await getCitiesByState(stateData.code);
const listings = await sql`
  SELECT l.id, l.slug, l.name, l.listing_type, l.tier, l.short_description,
         l.hero_image_url, l.neighborhood,
         c.name AS city_name, c.slug AS city_slug
  FROM listings l
  LEFT JOIN cities c ON c.id = l.city_id
  WHERE l.state_code = ${stateData.code}
    AND l.listing_type IN ('museum', 'cultural_center', 'sculpture_park')
    AND l.status = 'approved'
    AND l.deleted_at IS NULL
  ORDER BY CASE l.tier WHEN 'premium' THEN 1 WHEN 'featured' THEN 2 WHEN 'basic' THEN 3 ELSE 4 END, l.name
`;

const title = `Museums in ${stateData.name} | Southwest Galleries`;
const description = `Discover museums, cultural centers, and sculpture parks in ${stateData.name}. Browse ${listings.length} venue${listings.length === 1 ? '' : 's'} with hours, locations, and visitor information.`;

const museumEditorials: Record<string, string> = {
  arizona: `Arizona's museums range from the world-renowned Heard Museum in Phoenix — dedicated to Indigenous art and culture — to the Desert Botanical Garden, the Arizona-Sonora Desert Museum, and Scottsdale's celebrated contemporary institutions. Across the state, cultural centers preserve the living traditions of the Diné, Hopi, and other Indigenous nations alongside cutting-edge contemporary collections.`,
  california: `California is home to some of the most significant museum collections in the world, from the Getty Center and LACMA in Los Angeles to the San Diego Museum of Art and the Palm Springs Art Museum. The state's Southwest corridor adds a rich layer of desert and Indigenous culture to its already extraordinary institutional depth.`,
  colorado: `Colorado's museum landscape spans the Denver Art Museum — with one of the finest Native American art collections in the nation — to the Colorado Springs Fine Arts Center, the Aspen Art Museum, and the Boulder Museum of Contemporary Art. Mountain resort towns like Vail and Steamboat Springs also maintain impressive cultural institutions serving year-round visitors.`,
  nevada: `Nevada punches well above its weight in museum culture: the Nevada Museum of Art in Reno is the only accredited art museum in the state, while Las Vegas hosts the Bellagio Gallery of Fine Art and a growing number of cultural institutions in its booming downtown core. The state's frontier history and gaming culture have produced some of the most unexpected and compelling collection contexts in the Southwest.`,
  'new-mexico': `New Mexico's museum scene is extraordinary in its depth: the New Mexico Museum of Art, the Museum of International Folk Art, and the Museum of Indian Arts and Culture anchor Museum Hill in Santa Fe, while Albuquerque's Old Town hosts the New Mexico Museum of Natural History. The Georgia O'Keeffe Museum draws visitors from around the world to experience the work of the artist most associated with the Southwest's visual identity.`,
  texas: `Texas hosts some of the Southwest's most significant museum collections, anchored by the San Antonio Museum of Art — with its encyclopedic Latin American holdings — and the McNay Art Museum, one of the first museums of modern art in the state. San Antonio's cultural richness, combined with the contemporary scene in Austin and Houston, makes Texas one of the most museum-dense states in the region.`,
  utah: `Utah's museum landscape centers on the Utah Museum of Fine Arts and the Natural History Museum of Utah in Salt Lake City, with significant institutions in Provo, Ogden, and St. George. The state's extraordinary geological heritage and deep Mormon pioneer history give its collections a distinctive character found nowhere else in the Southwest.`,
};
const museumEditorial = museumEditorials[stateSlug] ?? `${stateData.name} has ${listings.length} museums, cultural centers, and sculpture parks listed on Southwest Galleries. Browse by city below to find hours, locations, and visitor information.`;

const bookingLink = `https://www.anrdoezrs.net/click-101807255-17293132?url=${encodeURIComponent('https://www.booking.com/searchresults.en-us.html?ss=' + stateData.name)}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How many museums are in ${stateData.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Southwest Galleries lists ${listings.length} museums, cultural centers, and sculpture parks in ${stateData.name}, spanning cities including ${(cities as any[]).slice(0, 4).map((c) => c.name).join(', ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `What are the best museums in ${stateData.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${stateData.name} has a wide range of acclaimed museums covering fine art, Native American culture, natural history, and contemporary art. Browse the full list above for details on each institution.`,
      },
    },
  ],
};
---

<Base {title} {description} schema={faqSchema}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Museums', href: '/museums/' },
        { label: stateData.name, href: `/museums/${stateSlug}/` },
        { label: 'Museums' },
      ]} />
      <h1>Museums in {stateData.name}</h1>
      <p>{museumEditorial}</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    {cities.length > 0 && (
      <div class="cities-grid" style="margin-bottom:2rem">
        {cities.map((city) => (
          <a href={`/museums/${stateSlug}/${city.slug}/`} class="city-pill">{city.name}</a>
        ))}
      </div>
    )}
    <div class="listings-grid">
      {listings.map((l) => (
        <ListingCard
          slug={l.slug} name={l.name} listing_type={l.listing_type} tier={l.tier}
          short_description={l.short_description} hero_image_url={l.hero_image_url}
          neighborhood={l.neighborhood} city_name={l.city_name} city_slug={l.city_slug}
          state_slug={stateSlug}
        />
      ))}
    </div>
    {listings.length === 0 && (
      <p style="color:var(--muted);text-align:center;padding:3rem">No museum listings yet. <a href="/submit/">Submit one →</a></p>
    )}
    <section class="hotel-cta">
      <div class="hotel-cta-inner">
        <div class="hotel-cta-text">
          <h2>Where to Stay in {stateData.name}</h2>
          <p>Find hotels, inns, and vacation rentals near {stateData.name}'s museums and cultural venues.</p>
        </div>
        <a href={bookingLink} target="_blank" rel="noopener noreferrer sponsored" class="hotel-cta-btn">
          Search Hotels on Booking.com →
        </a>
      </div>
    </section>
  </div>
</Base>

<style>
  .cities-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .city-pill { padding: 0.4rem 0.9rem; border: 1px solid var(--border); border-radius: 20px; font-size: 0.875rem; color: var(--ink); text-decoration: none; }
  .city-pill:hover { background: var(--sand); border-color: var(--turquoise); text-decoration: none; }
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .hotel-cta { margin-top: 3rem; background: var(--surface); border-radius: 10px; padding: 1.75rem 2rem; }
  .hotel-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .hotel-cta-text h2 { font-size: 1.2rem; font-weight: 700; color: var(--sand); margin-bottom: 0.35rem; }
  .hotel-cta-text p { font-size: 0.9rem; color: var(--surface-muted); margin: 0; line-height: 1.5; }
  .hotel-cta-btn { display: inline-block; background: #003580; color: #fff; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
  .hotel-cta-btn:hover { background: #002a6b; text-decoration: none; }
</style>
