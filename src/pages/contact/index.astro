---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
---

<Base
  title="Contact Southwest Galleries"
  description="Get in touch with Southwest Galleries. Questions about listings, editorial content, partnerships, or advertising — we'd love to hear from you."
>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
      <h1>Contact Us</h1>
      <p>Questions, feedback, or partnership inquiries — we're here.</p>
    </div>
  </div>

  <div class="container content-container">
    <div class="contact-grid">

      <div class="contact-main">
        <h2>Get in Touch</h2>
        <p>The best way to reach us is by email. We respond to all inquiries within two business days.</p>
        <a href="mailto:hello@southwestgalleries.com" class="email-link">hello@southwestgalleries.com</a>

        <div class="contact-topics">
          <h3>What can we help with?</h3>
          <ul>
            <li><strong>Listing questions</strong> — adding, updating, or claiming a gallery or venue listing</li>
            <li><strong>Editorial</strong> — corrections, suggestions, or pitching a guide topic</li>
            <li><strong>Advertising and partnerships</strong> — sponsored content, affiliate programs, or co-marketing</li>
            <li><strong>Press and media</strong> — interviews, data requests, or media inquiries</li>
            <li><strong>General feedback</strong> — anything else on your mind</li>
          </ul>
        </div>
      </div>

      <div class="contact-sidebar">
        <div class="sidebar-card">
          <h3>Submit a Listing</h3>
          <p>Want to add your gallery, museum, or studio to our directory? Use our submission form.</p>
          <a href="/submit/" class="sidebar-btn">Submit a Listing →</a>
        </div>
        <div class="sidebar-card">
          <h3>Submit an Event</h3>
          <p>Have an opening, art walk, or cultural event to share? Submit it for our events calendar.</p>
          <a href="/submit-event/" class="sidebar-btn">Submit an Event →</a>
        </div>
        <div class="sidebar-card">
          <h3>Claim Your Listing</h3>
          <p>Already listed? Claim your venue to update your information and unlock premium options.</p>
          <a href="/galleries/" class="sidebar-btn">Find Your Listing →</a>
        </div>
      </div>

    </div>
  </div>
</Base>

<style>
  .content-container { padding-top: 2.5rem; padding-bottom: 4rem; }
  .contact-grid { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; align-items: start; }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; } }

  .contact-main h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 0.75rem; }
  .contact-main p { color: var(--muted); line-height: 1.7; margin-bottom: 1rem; }

  .email-link {
    display: inline-block; font-size: 1.2rem; font-weight: 700;
    color: var(--clay); text-decoration: none;
    border-bottom: 2px solid var(--clay); padding-bottom: 2px;
    margin-bottom: 2rem;
  }
  .email-link:hover { opacity: 0.8; }

  .contact-topics h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.75rem; }
  .contact-topics ul { margin-left: 1.25rem; }
  .contact-topics li { margin-bottom: 0.6rem; color: var(--muted); line-height: 1.6; }
  .contact-topics li strong { color: var(--ink); }

  .sidebar-card {
    background: var(--sand); border: 1px solid var(--border);
    border-radius: 10px; padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .sidebar-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.4rem; }
  .sidebar-card p { font-size: 0.875rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.75rem; }
  .sidebar-btn {
    display: inline-block; font-size: 0.875rem; font-weight: 700;
    color: var(--clay); text-decoration: none;
  }
  .sidebar-btn:hover { text-decoration: underline; }
</style>
