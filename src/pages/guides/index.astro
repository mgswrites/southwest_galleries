---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getPublishedPosts } from '../../lib/queries';

const posts = await getPublishedPosts();
---

<Base
  title="Southwest Art Guides | Southwest Galleries"
  description="In-depth editorial guides to galleries, museums, and the art scene across Arizona, New Mexico, Colorado, Texas, and the broader American Southwest."
>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'Guides' }]} />
      <h1>Southwest Art Guides</h1>
      <p>In-depth guides to galleries, neighborhoods, and the art scene across the Southwest.</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    <p class="guides-intro">Our editorial team explores the galleries, districts, and art scenes that define the American Southwest. From the storied museum mile of Santa Fe to the booming creative quarters of Phoenix and Denver, these in-depth guides help you plan your next art adventure, discover emerging artists, and understand the cultural forces shaping the region's creative identity.</p>
    {posts.length > 0 ? (
      <div class="posts-grid">
        {posts.map((p) => (
          <a href={`/guides/${p.slug}/`} class="post-card">
            {p.hero_image_url && (
              <img src={p.hero_image_url} alt={p.title} loading="lazy" width="400" height="225" />
            )}
            <div class="post-body">
              <h2>{p.title}</h2>
              {p.excerpt && <p>{p.excerpt}</p>}
              <span class="post-meta">
                {p.author_name}
                {p.published_at && ` · ${new Date(p.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}`}
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="color:var(--muted);text-align:center;padding:3rem">Editorial guides coming soon.</p>
    )}
    <section class="hotel-cta">
      <div class="hotel-cta-inner">
        <div class="hotel-cta-text">
          <h2>Planning a Trip to the Southwest?</h2>
          <p>Find hotels, inns, and vacation rentals near galleries and cultural venues across all seven states.</p>
        </div>
        <div>
          <a href="https://www.anrdoezrs.net/click-101807255-17293132" target="_blank" rel="noopener noreferrer sponsored" class="hotel-cta-btn">Search Hotels on Booking.com →</a>
          <p class="hotel-disclosure">Affiliate link. We may earn a commission at no cost to you.</p>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .guides-intro { max-width: 720px; margin-bottom: 2rem; color: var(--muted); line-height: 1.7; font-size: 0.95rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .post-card { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; color: inherit; text-decoration: none; transition: box-shadow 0.2s, transform 0.2s; }
  .post-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .post-card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
  .post-body { padding: 1.25rem; }
  .post-body h2 { font-size: 1.05rem; font-weight: 700; line-height: 1.35; margin-bottom: 0.5rem; }
  .post-body p { font-size: 0.875rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .post-meta { font-size: 0.75rem; color: #999; }
  .hotel-cta { margin-top: 3rem; background: var(--surface); border-radius: 10px; padding: 1.75rem 2rem; }
  .hotel-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .hotel-cta-text h2 { font-size: 1.2rem; font-weight: 700; color: var(--sand); margin-bottom: 0.35rem; }
  .hotel-cta-text p { font-size: 0.9rem; color: var(--surface-muted); margin: 0; line-height: 1.5; }
  .hotel-cta-btn { display: inline-block; background: #003580; color: #fff; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
  .hotel-cta-btn:hover { background: #002a6b; text-decoration: none; }
  .hotel-disclosure { font-size: 0.7rem; color: rgba(255,255,255,0.65); margin-top: 0.5rem; text-align: center; }
</style>
