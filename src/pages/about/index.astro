---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
---

<Base
  title="About Southwest Galleries | Our Mission"
  description="Discover galleries, museums, and cultural venues across the American Southwest. Your definitive guide to art in Arizona, New Mexico, Colorado, Texas, and beyond."
>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]} />
      <h1>About Southwest Galleries</h1>
      <p>Connecting art lovers with the extraordinary creative culture of the American Southwest.</p>
    </div>
  </div>

  <div class="container content-container">

    <div class="about-main">
      <section class="about-section">
        <h2>Our Mission</h2>
        <p>
          Southwest Galleries was built on a simple belief: the American Southwest is home to one of the
          world's most vibrant and underappreciated art scenes, and it deserves a directory worthy of it.
        </p>
        <p>
          From the Indigenous ceramic traditions of New Mexico and Arizona to the contemporary galleries of
          Houston and Los Angeles, from plein air painters working in the Sangre de Cristo Mountains to
          glass artists firing kilns in the back roads of Colorado, the Southwest is alive with creative energy.
          We're here to make it discoverable.
        </p>
      </section>

      <section class="about-section">
        <h2>What We Cover</h2>
        <div class="what-grid">
          <div class="what-card">
            <img src="https://images.unsplash.com/photo-1554907984-15263bfd63bd?w=600&h=320&fit=crop&q=80" alt="Art gallery interior with framed paintings on red walls" loading="lazy" />
            <div class="what-card-body">
              <h3>Art Galleries</h3>
              <p>Commercial galleries, artist-run spaces, and cooperative galleries across all seven states.</p>
            </div>
          </div>
          <div class="what-card">
            <img src="https://images.unsplash.com/photo-1582555172866-f73bb12a2ab3?w=600&h=320&fit=crop&q=80" alt="Visitor viewing framed artwork in a museum gallery" loading="lazy" />
            <div class="what-card-body">
              <h3>Museums</h3>
              <p>Art museums, cultural history museums, and specialized collections from major cities to remote towns.</p>
            </div>
          </div>
          <div class="what-card">
            <img src="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=600&h=320&fit=crop&q=80" alt="Child with colorful paint, representing community arts education" loading="lazy" />
            <div class="what-card-body">
              <h3>Cultural Centers</h3>
              <p>Community arts organizations, tribal cultural centers, and nonprofit arts institutions.</p>
            </div>
          </div>
          <div class="what-card">
            <img src="https://images.unsplash.com/photo-1547826039-bfc35e0f1ea8?w=600&h=320&fit=crop&q=80" alt="Colorful abstract painting on canvas in an artist studio" loading="lazy" />
            <div class="what-card-body">
              <h3>Artist Studios</h3>
              <p>Working studios open to the public, studio tours, and artist residency programs.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="about-section">
        <h2>Our Region</h2>
        <p>
          We cover the seven states that define the American Southwest: <strong>Arizona</strong>, <strong>New Mexico</strong>,
          <strong>Colorado</strong>, <strong>Nevada</strong>, <strong>Utah</strong>, <strong>Texas</strong>, and <strong>California</strong>.
          From Taos to Tucson, Marfa to Moab, Sedona to San Francisco. If it's art and it's in the Southwest, it belongs here.
        </p>
        <p>
          We give particular depth to the region's most storied art communities: Santa Fe and Taos, the oldest art
          markets in the country; Phoenix and Scottsdale, with their world-class museum infrastructure; the canyon
          country of Utah and Colorado, which has inspired landscape painters for over a century; and the Indigenous
          art traditions of the Diné Nation, Pueblo communities, and beyond.
        </p>
      </section>

      <section class="about-section founder-section">
        <h2>About the Founder</h2>
        <div class="founder-inner">
          <div class="founder-photo-wrap">
            <img
              src="/453096715_473831632262097_4434383762082902381_n_473831635595430.jpg"
              alt="M.G. Salazar at the Tribeca Film Festival"
              class="founder-photo"
            />
          </div>
          <div class="founder-bio">
            <h3>M.G. Salazar</h3>
            <p>
              M.G. Salazar is a native New Mexican, two-time Creative Arts Emmy Award winner, and
              multiple grant-winning multi-disciplinary artist. The author of three books and founder
              of La Resistencia Press, Salazar holds a Professional Certification in Nonprofit Arts
              Management from New York University and has spent a career amplifying voices and stories
              rooted in the American Southwest — as a writer, filmmaker, and cultural advocate.
            </p>
            <p>
              Southwest Galleries grows out of that same commitment: a belief that the artists,
              galleries, and cultural institutions of the Southwest deserve a platform as serious and
              passionate as the work they produce. Built by someone from here, for everyone who loves
              this place.
            </p>
          </div>
        </div>
      </section>

      <section class="about-section">
        <h2>Contact</h2>
        <p>
          Questions, corrections, or partnership inquiries? Reach us at
          <a href="mailto:hello@southwestgalleries.com">hello@southwestgalleries.com</a>.
          We read every message.
        </p>
        <p>
          You can also find us on Facebook:
          <a href="https://www.facebook.com/profile.php?id=61590338354686" target="_blank" rel="noopener noreferrer">Southwest Galleries on Facebook</a>.
        </p>
      </section>
    </div>

    <aside class="about-sidebar">
      <div class="sidebar-block">
        <h3>List Your Venue</h3>
        <p>Southwest Galleries is free to join. Basic listings are reviewed within 2–3 business days and published at no cost.</p>
        <p>Featured and Premium tiers are available for venues that want enhanced visibility and direct access to collectors.</p>
        <div class="cta-row">
          <a href="/submit/" class="btn-primary">Submit Your Listing</a>
          <a href="/upgrade/" class="btn-outline">View Premium Options</a>
        </div>
      </div>
      <div class="sidebar-block">
        <h3>Browse the Directory</h3>
        <p>Explore galleries, museums, and cultural venues across all seven states of the American Southwest.</p>
        <div class="cta-row">
          <a href="/galleries/" class="btn-primary">Browse Galleries</a>
          <a href="/museums/" class="btn-outline">Browse Museums</a>
        </div>
      </div>
    </aside>

  </div>
</Base>

<style>
  .content-container {
    padding-top: 1.5rem;
    padding-bottom: 5rem;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 0 4rem;
    align-items: start;
  }

  .about-main { display: flex; flex-direction: column; }

  .about-section {
    margin-bottom: 3rem;
  }
  .about-section h2 {
    font-size: 1.35rem;
    margin-bottom: 0.9rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
    color: var(--ink);
  }
  .about-section p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    margin-bottom: 0.9rem;
  }
  .about-section p:last-child { margin-bottom: 0; }
  .about-section strong { color: var(--ink); }

  .what-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .what-card {
    background: var(--sand);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    color: var(--ink);
  }
  .what-card img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    display: block;
  }
  .what-card-body { padding: 1rem 1.1rem 1.1rem; }
  .what-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; color: var(--ink); }
  .what-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.6; margin: 0; }

  .about-sidebar {
    position: sticky;
    top: 120px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .sidebar-block {
    background: var(--surface);
    border-radius: 8px;
    padding: 1.5rem;
    color: var(--sand);
  }
  .sidebar-block h3 {
    font-size: 1rem;
    color: var(--sand);
    margin-bottom: 0.6rem;
  }
  .sidebar-block p { font-size: 0.875rem; color: var(--surface-muted); line-height: 1.6; margin-bottom: 1rem; }
  .sidebar-block p:last-child { margin-bottom: 0; }

  .cta-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }
  .btn-primary {
    background: var(--turquoise);
    color: #fff;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    text-align: center;
  }
  .btn-primary:hover { background: #0a7070; text-decoration: none; }
  .btn-outline {
    color: var(--sand);
    padding: 0.65rem 1.5rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    border: 1.5px solid #5a4a30;
    text-align: center;
  }
  .btn-outline:hover { border-color: var(--sand); text-decoration: none; }

  .founder-inner {
    display: flex;
    gap: 1.75rem;
    align-items: stretch;
    margin-top: 0.5rem;
  }
  .founder-photo-wrap { flex-shrink: 0; width: 180px; align-self: stretch; }
  .founder-photo {
    width: 180px;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    border-radius: 8px;
    display: block;
    border: 3px solid var(--border);
  }
  .founder-bio h3 {
    font-family: 'Rye', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--clay);
    margin-bottom: 0.75rem;
  }

  @media (max-width: 860px) {
    .content-container { grid-template-columns: 1fr; }
    .about-sidebar { position: static; }
    .what-grid { grid-template-columns: 1fr 1fr; }
    .cta-row { flex-direction: row; }
  }
  @media (max-width: 500px) {
    .what-grid { grid-template-columns: 1fr; }
  }
</style>
