---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';

const TIERS = [
  {
    name: 'Free',
    price: '$0',
    period: '',
    description: 'Get listed in the directory.',
    features: [
      'Name, address & contact info',
      'Listed on city and state pages',
      'Art style & category tags',
      'Link to your website',
      'Reviewed within 2–3 business days',
    ],
    cta: 'Submit a Free Listing',
    ctaHref: '/submit/',
    highlight: false,
    badge: null,
  },
  {
    name: 'Basic',
    price: '$99',
    period: '/year',
    description: 'A complete, compelling profile.',
    features: [
      'Everything in Free',
      'Hero image on your listing page',
      'Full venue description (up to 2,000 chars)',
      'Hours, phone & email displayed',
      'Neighborhood / district tag',
    ],
    cta: 'Get Basic',
    ctaHref: '/submit/',
    highlight: false,
    badge: null,
  },
  {
    name: 'Featured',
    price: '$199',
    period: '/year',
    description: 'Stand out across the directory.',
    features: [
      'Everything in Basic',
      'Featured badge on listing card',
      'Priority placement on city pages',
      'Featured section on state hub pages',
      'Included in homepage featured rotation',
    ],
    cta: 'Get Featured',
    ctaHref: '/submit/',
    highlight: true,
    badge: 'Most Popular',
  },
  {
    name: 'Premium',
    price: '$349',
    period: '/year',
    description: 'Maximum visibility, top of every page.',
    features: [
      'Everything in Featured',
      'Premium badge on listing card',
      'Top placement on all search results',
      'Logo displayed on your listing page',
      'Annual view count analytics report',
      'Consideration for editorial guides',
    ],
    cta: 'Get Premium',
    ctaHref: '/submit/',
    highlight: false,
    badge: null,
  },
];

const FAQS = [
  {
    q: 'How do I upgrade an existing listing?',
    a: 'Email us at hello@southwestgalleries.com with your venue name and desired plan. We\'ll send you a secure payment link and upgrade your listing within one business day.',
  },
  {
    q: 'Can I upgrade or downgrade later?',
    a: 'Yes. You can upgrade at any time and we\'ll prorate the difference. Downgrades take effect at your next renewal date.',
  },
  {
    q: 'What payment methods do you accept?',
    a: 'All major credit and debit cards via Stripe. We do not store card details on our servers.',
  },
  {
    q: 'Is there a contract or commitment?',
    a: 'All plans are billed annually with no long-term contract. Cancel before your renewal date and you won\'t be charged again.',
  },
  {
    q: 'What counts as "top placement"?',
    a: 'Premium listings appear first in city, state, and art-style pages, above Featured, Basic, and Free listings. Within Premium, ordering rotates periodically so no single venue always appears first.',
  },
];
---

<Base
  title="Premium Options & Pricing | Southwest Galleries"
  description="Choose the right visibility tier for your gallery, museum, or cultural venue. Plans from free to $349/year."
  noindex
>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'Premium Options' }]} />
      <h1>Plans &amp; Pricing</h1>
      <p>More visibility. More collectors. More visitors.</p>
    </div>
  </div>

  <div class="container pricing-container">

    <div class="tiers-grid">
      {TIERS.map((tier) => (
        <div class={`tier-card${tier.highlight ? ' highlight' : ''}`}>
          {tier.badge && <div class="badge">{tier.badge}</div>}
          <div class="tier-header">
            <h2>{tier.name}</h2>
            <p class="tier-desc">{tier.description}</p>
            <div class="price-row">
              <span class="price">{tier.price}</span>
              {tier.period && <span class="period">{tier.period}</span>}
            </div>
          </div>
          <ul class="feature-list">
            {tier.features.map((f) => (
              <li><span class="check" aria-hidden="true">✓</span>{f}</li>
            ))}
          </ul>
          <a href={tier.ctaHref} class={`cta-btn${tier.highlight ? ' primary' : ''}`}>
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="upgrade-note">
      Already listed? Email <a href="mailto:hello@southwestgalleries.com">hello@southwestgalleries.com</a> to upgrade your existing listing.
    </p>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        {FAQS.map((item) => (
          <div class="faq-item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </section>

  </div>
</Base>

<style>
  .page-header { background: var(--sand); border-bottom: 1px solid var(--border); padding: 2.5rem 0 2rem; }
  .page-header h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin-bottom: 0.4rem; }
  .page-header p { color: var(--muted); font-size: 1rem; }

  .pricing-container { padding-top: 2.5rem; padding-bottom: 5rem; }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 1000px) { .tiers-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .tiers-grid { grid-template-columns: 1fr; max-width: 420px; } }

  .tier-card {
    border: 1.5px solid #3d3020;
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    position: relative;
    background: var(--surface);
    color: var(--sand);
    display: flex;
    flex-direction: column;
  }
  .tier-card.highlight {
    border-color: var(--turquoise);
    box-shadow: 0 4px 24px rgba(13, 140, 140, 0.25);
  }

  .badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--turquoise); color: #fff;
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; padding: 0.22rem 0.75rem; border-radius: 20px;
    white-space: nowrap;
  }

  .tier-header { margin-bottom: 1.25rem; }
  .tier-header h2 { font-size: 1.2rem; font-weight: 800; margin-bottom: 0.25rem; }
  .tier-desc { font-size: 0.825rem; color: var(--surface-muted); margin-bottom: 0.75rem; }
  .price-row { display: flex; align-items: baseline; gap: 0.2rem; }
  .price { font-size: 2.1rem; font-weight: 800; color: var(--sand); }
  .period { font-size: 0.875rem; color: var(--surface-muted); }

  .feature-list {
    list-style: none; padding: 0; margin: 0 0 1.5rem;
    display: flex; flex-direction: column; gap: 0.55rem;
    flex: 1;
  }
  .feature-list li { display: flex; gap: 0.55rem; font-size: 0.875rem; line-height: 1.4; }
  .check { color: var(--turquoise); font-weight: 700; flex-shrink: 0; }

  .cta-btn {
    display: block; width: 100%; padding: 0.7rem 1rem;
    background: #3d3020; border: 1.5px solid #5a4a30;
    border-radius: 8px; font-size: 0.95rem; font-weight: 700;
    cursor: pointer; text-align: center; text-decoration: none;
    color: var(--sand); transition: all 0.15s;
    font-family: inherit;
  }
  .cta-btn.primary { background: var(--turquoise); border-color: var(--turquoise); color: #fff; }
  .cta-btn:hover { opacity: 0.85; text-decoration: none; }

  .upgrade-note {
    text-align: center; margin-top: 2rem;
    font-size: 0.9rem; color: var(--muted);
  }
  .upgrade-note a { color: var(--turquoise); }

  .faq-section { margin-top: 4rem; }
  .faq-section h2 { font-size: 1.4rem; font-weight: 800; margin-bottom: 1.5rem; }
  .faq-list { display: flex; flex-direction: column; gap: 1.5rem; max-width: 720px; }
  .faq-item h3 { font-size: 0.975rem; font-weight: 700; margin-bottom: 0.4rem; }
  .faq-item p { font-size: 0.9rem; color: var(--muted); line-height: 1.65; }
</style>
