---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getArtStyles, getArtStyle, getListingsByArtStyle } from '../../lib/queries';

export async function getStaticPaths() {
  const styles = await getArtStyles();
  return styles.map((s) => ({ params: { style: s.slug } }));
}

const { style: styleSlug } = Astro.params;
const styleData = await getArtStyle(styleSlug!);
if (!styleData) return Astro.redirect('/art-styles/');

const listings = await getListingsByArtStyle(styleData.id);

// Group by state, preserving tier-then-name sort within each group
const byState = listings.reduce((acc, l) => {
  const key = l.state_name ?? 'Other';
  if (!acc.has(key)) acc.set(key, []);
  acc.get(key)!.push(l);
  return acc;
}, new Map<string, typeof listings>());
const stateGroups = [...byState.entries()].sort(([a], [b]) => a.localeCompare(b));

const title = styleData.meta_title ?? `${styleData.name} Art Galleries in the Southwest | Southwest Galleries`;
const description = styleData.meta_description ?? styleData.description ?? `Find galleries specializing in ${styleData.name} art across the American Southwest.`;

const styleEditorials: Record<string, string> = {
  abstract: `Abstract art in the Southwest takes on a distinctive character rooted in the region's dramatic landscapes and spiritual traditions. From stark geometry inspired by Taos Pueblo's adobe forms to expansive color field work emerging from Phoenix and Denver's studio scenes, Southwest abstractionists engage deeply with their environment. Collectors will find work ranging from intimate mixed-media pieces to large-scale installations in galleries from Tucson to Santa Fe.`,
  'adobe-pueblo': `The adobe and pueblo tradition is one of the most distinctive visual languages of the American Southwest, rooted in centuries of Pueblo building practice in New Mexico and Arizona. Galleries showcasing this style celebrate both the functional beauty of earthen architecture and the decorative arts — painting, pottery, and textile — that grew alongside it. Santa Fe and Albuquerque are the primary centers for this work, with venues spanning historic adobe spaces and contemporary gallery districts alike.`,
  'ceramics-pottery': `Ceramics and pottery occupy a uniquely honored place in the Southwest's artistic traditions. Pueblo pottery — particularly the black-on-black ware pioneered by María Martínez of San Ildefonso Pueblo — has been recognized as among the finest ceramic art in the world. Today the tradition continues through a new generation of Indigenous and non-Indigenous studio ceramicists working across New Mexico, Arizona, and Colorado.`,
  contemporary: `Contemporary art in the Southwest has grown from a regional scene into one of national and international significance. Cities like Phoenix, Denver, and Santa Fe host galleries showing work engaging with post-Minimalism, social practice, and digital media, while smaller markets like Marfa, Taos, and Bisbee have cultivated devoted collector communities. The Southwest's landscape, Indigenous culture, and frontier mythology give its contemporary scene a conceptual richness found nowhere else.`,
  figurative: `Figurative art has deep roots in the Southwest, from the portrait traditions of Spanish colonial painting to the figure-centered canvases of Taos Society of Artists masters like Ernest Blumenschein and Bert Geer Phillips. Contemporary figurative painters working in the region draw on this legacy while pushing the form in bold new directions, producing work celebrated in galleries from Santa Fe to Los Angeles.`,
  'glass-art': `Glass art has found fertile ground in the Southwest, where the Native American tradition of turquoise and silver craftsmanship meets a contemporary studio movement producing ambitious blown and kiln-formed glass. Artists working in Tucson, Albuquerque, and the Denver area have established a regional glass scene that regularly attracts both collectors and museum acquisition committees.`,
  jewelry: `Southwest jewelry — particularly the turquoise-and-silver work developed collaboratively by Navajo, Zuni, and Hopi artisans — is recognized as one of the great American art forms. From intricately stamped concho belts to elegant contemporary inlay work, the tradition spans centuries and continues to evolve in the hands of both Native and non-Native artists. Major markets for Southwest jewelry are found in Santa Fe, Scottsdale, and Albuquerque.`,
  'landscape-plein-air': `Plein Air painting — working from direct observation outdoors — has been central to the Southwest art tradition since the late 19th century, when painters arriving from the East were transformed by the region's extraordinary light and vast open spaces. Today the tradition is thriving, with active painting societies across Arizona, New Mexico, Colorado, and Utah, and major annual competitions drawing artists from across the country. The resulting work captures the living landscape in a way photography cannot, distilling the emotional essence of desert, canyon, and mountain.`,
  'native-american': `Native American art is one of the oldest and most vital traditions in the American Southwest, encompassing pottery, weaving, jewelry, kachina carving, painting, and sculpture produced by the Navajo, Hopi, Zuni, Pueblo, Apache, and dozens of other nations. The work ranges from centuries-old ceremonial objects to cutting-edge contemporary installations by artists like Jaune Quick-to-See Smith and Rose Simpson. Southwest Galleries features both established institutions and artist-run galleries that support Indigenous artists and keep these traditions living and evolving.`,
  photography: `Photography has played a defining role in how the world sees the American Southwest, from Ansel Adams's iconic images of Canyon de Chelly to Laura Gilpin's intimate portraits of Navajo life. Today a new generation of Southwest photographers challenge those canonical images with work centering Indigenous perspectives, contemporary desert urbanism, and the living cultures of the borderlands. Fine art photography galleries across the region represent both established and emerging voices.`,
  sculpture: `Sculpture in the Southwest takes full advantage of the region's outdoor spaces and monumental scale — from the landmark installations of the Chinati Foundation in Marfa to the outdoor sculpture gardens of Scottsdale and the public art programs of Santa Fe and Denver. Studio sculptors working in bronze, stone, steel, and found materials have made the region a center for both representational Western sculpture and adventurous contemporary three-dimensional work.`,
  'western-cowboy': `The Western American art tradition — encompassing the heroic landscapes, wildlife, and cowboy subjects pioneered by Frederic Remington and Charles Russell — remains one of the most commercially vibrant genres in the Southwest gallery world. Scottsdale's Cowboy Artists of America and major Western art auctions held annually across the region draw serious collectors and consistently achieve significant prices. Contemporary Western artists honor the tradition while expanding its subject matter to include the full diversity of the modern West.`,
};

const editorial = styleData.description ?? styleEditorials[styleSlug] ?? `Explore galleries and venues across the American Southwest specializing in ${styleData.name} art.`;

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: new URL(`/art-styles/${styleSlug}/`, Astro.site).toString(),
};
---

<Base {title} {description} schema={collectionSchema}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Art Styles', href: '/art-styles/' },
        { label: styleData.name },
      ]} />
      <h1>{styleData.name} Art Galleries</h1>
      <p>{editorial}</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    {listings.length > 0 ? (
      <>
        {stateGroups.length > 1 && (
          <nav class="state-jumps" aria-label="Jump to state">
            {stateGroups.map(([stateName]) => {
              const anchor = stateName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
              return (
                <a href={`#${anchor}`} class="jump-btn">{stateName}</a>
              );
            })}
          </nav>
        )}
        {stateGroups.map(([stateName, items]) => {
          const anchor = stateName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          return (
            <section class="state-section" id={anchor}>
              <h2 class="state-heading">{stateName}</h2>
              <div class="listings-grid">
                {items.map((l: (typeof listings)[number]) => (
                  <ListingCard
                    slug={l.slug} name={l.name} listing_type={l.listing_type} tier={l.tier}
                    short_description={l.short_description} hero_image_url={l.hero_image_url}
                    neighborhood={l.neighborhood} city_name={l.city_name} city_slug={l.city_slug}
                    state_slug={l.state_slug}
                  />
                ))}
              </div>
              <div class="section-footer">
                <a href="#" class="back-top-btn" aria-label="Back to top">↑ Back to top</a>
              </div>
            </section>
          );
        })}
      </>
    ) : (
      <p style="color:var(--muted);text-align:center;padding:3rem">
        No listings yet for this style. <a href="/submit/">Submit one →</a>
      </p>
    )}
  </div>
</Base>

<style>
  .state-jumps { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
  .jump-btn {
    display: inline-block; padding: 0.4rem 1rem; border: 1.5px solid var(--turquoise);
    border-radius: 999px; font-size: 0.85rem; font-weight: 600; color: var(--turquoise);
    text-decoration: none; transition: background 0.15s, color 0.15s;
  }
  .jump-btn:hover { background: var(--turquoise); color: #fff; }
  .state-section { margin-bottom: 3rem; scroll-margin-top: 5rem; }
  .state-heading { font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem; padding-bottom: 0.4rem; border-bottom: 2px solid var(--border); color: var(--ink); }
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
  .section-footer { display: flex; justify-content: flex-end; margin-top: 1rem; }
  .back-top-btn {
    font-size: 0.8rem; font-weight: 600; color: var(--muted); text-decoration: none;
    padding: 0.3rem 0.75rem; border: 1px solid var(--border); border-radius: 999px;
    transition: color 0.15s, border-color 0.15s;
  }
  .back-top-btn:hover { color: var(--turquoise); border-color: var(--turquoise); }
</style>
