---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getArtStyles } from '../../lib/queries';

const styles = await getArtStyles();
---

<Base
  title="Art Styles in the Southwest | Southwest Galleries"
  description="Explore Southwest galleries by art style. Find venues specializing in Native American art, Western painting, Contemporary work, Plein Air landscapes, Ceramics, and more."
>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'Art Styles' }]} />
      <h1>Browse by Art Style</h1>
      <p>Find galleries and venues specializing in specific styles of Southwest art.</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    <p class="styles-intro">The American Southwest has nurtured a remarkable breadth of artistic traditions. From the ancient ceramic arts of Pueblo peoples to the sweeping Plein Air landscapes painted on canyon rims, from gallery-hopping Santa Fe to the cutting-edge Contemporary scenes of Phoenix and Denver, the region rewards every kind of art lover. Browse the styles below to find galleries and venues that match your taste.</p>
    <div class="styles-grid">
      {styles.map((s) => (
        <a href={`/art-styles/${s.slug}/`} class="style-card">
          <div class="style-img" style={`background-image: url('/art-styles/${s.slug}.jpg')`}>
            <div class="style-overlay"></div>
            <div class="style-label">
              <h2>{s.name}</h2>
              {s.description && <p>{s.description}</p>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .styles-intro { max-width: 720px; margin-bottom: 2rem; color: var(--muted); line-height: 1.7; font-size: 0.95rem; }
  .styles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.25rem; }
  .style-card { border-radius: 10px; overflow: hidden; text-decoration: none; display: block; transition: transform 0.2s, box-shadow 0.2s; }
  .style-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.18); text-decoration: none; }
  .style-img {
    position: relative;
    height: 200px;
    background-size: cover;
    background-position: center;
    background-color: var(--sand);
  }
  .style-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.2) 55%, rgba(0,0,0,0.0) 100%);
  }
  .style-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
  }
  .style-label h2 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.2rem; }
  .style-label p { font-size: 0.78rem; color: rgba(255,255,255,0.8); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  @media (max-width: 600px) { .styles-grid { grid-template-columns: 1fr 1fr; } }
</style>
