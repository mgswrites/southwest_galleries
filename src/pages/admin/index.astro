---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { getPendingSubmissions, updateSubmissionStatus, createListing } from '../../lib/queries';
import sql from '../../lib/db';

const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD ?? 'changeme';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const isAuthed = cookieHeader.includes('admin_authed=1');

let authError = false;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action') as string ?? '';

  if (action === 'login') {
    const pw = data.get('password') as string;
    if (pw === ADMIN_PASSWORD) {
      return new Response(null, {
        status: 302,
        headers: {
          'Set-Cookie': 'admin_authed=1; Path=/admin; HttpOnly; SameSite=Strict',
          'Location': '/admin/',
        },
      });
    } else {
      authError = true;
    }
  } else if (isAuthed) {
    if (action === 'logout') {
      return new Response(null, {
        status: 302,
        headers: {
          'Set-Cookie': 'admin_authed=; Path=/admin; HttpOnly; Expires=Thu, 01 Jan 1970 00:00:00 GMT',
          'Location': '/admin/',
        },
      });
    }

    // Submission actions
    const submissionId = Number(data.get('submission_id'));
    if (submissionId && ['approve', 'reject', 'needs_info'].includes(action)) {
      if (action === 'approve') {
        const sub = await sql`SELECT * FROM listing_submissions WHERE id = ${submissionId}`;
        if (sub[0]) {
          const s = sub[0];
          const cityRows = await sql`
            SELECT id FROM cities WHERE LOWER(name) = LOWER(${s.city_name}) AND state_code = ${s.state_code} LIMIT 1
          `;
          const cityId = cityRows[0]?.id ?? null;
          const slugBase = (s.name as string).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
          const existingSlug = await sql`SELECT slug FROM listings WHERE slug LIKE ${slugBase + '%'} ORDER BY slug DESC LIMIT 1`;
          const slug = existingSlug.length > 0 ? `${slugBase}-${Date.now()}` : slugBase;
          const created = await createListing({
            slug, name: s.name, listing_type: s.listing_type, state_code: s.state_code,
            city_id: cityId, address: s.address, website_url: s.website_url,
            phone: s.phone, email: s.email, description: s.description,
          });
          await updateSubmissionStatus(submissionId, 'approved', created.id);
        }
      } else {
        await updateSubmissionStatus(submissionId, action === 'reject' ? 'rejected' : 'needs_info');
      }
    }

    // Claim actions
    const claimId = Number(data.get('claim_id'));
    if (claimId && ['approve_claim', 'reject_claim'].includes(action)) {
      const status = action === 'approve_claim' ? 'approved' : 'rejected';
      await sql`UPDATE listing_claims SET status = ${status}, reviewed_at = NOW() WHERE id = ${claimId}`;
    }
  }
}

const tab = Astro.url.searchParams.get('tab') ?? 'submissions';

let submissions: any[] = [];
let claims: any[] = [];
let subscribers: any[] = [];
let stats = { totalListings: 0, pendingSubmissions: 0, pendingClaims: 0, totalSubscribers: 0 };

if (isAuthed) {
  submissions = await getPendingSubmissions();

  claims = await sql`
    SELECT lc.*, l.name AS listing_name, l.slug AS listing_slug
    FROM listing_claims lc
    JOIN listings l ON l.id = lc.listing_id
    WHERE lc.status = 'pending'
    ORDER BY lc.created_at DESC
  `;

  subscribers = await sql`
    SELECT id, email, source, created_at FROM subscribers ORDER BY created_at DESC
  `;

  const [ls, ps, pc, ts] = await Promise.all([
    sql`SELECT COUNT(*) AS n FROM listings WHERE status = 'approved' AND deleted_at IS NULL`,
    sql`SELECT COUNT(*) AS n FROM listing_submissions WHERE status = 'pending'`,
    sql`SELECT COUNT(*) AS n FROM listing_claims WHERE status = 'pending'`,
    sql`SELECT COUNT(*) AS n FROM subscribers`,
  ]);
  stats = {
    totalListings: Number(ls[0].n),
    pendingSubmissions: Number(ps[0].n),
    pendingClaims: Number(pc[0].n),
    totalSubscribers: Number(ts[0].n),
  };
}
---

<Base title="Admin | Southwest Galleries" noindex>
  <div class="admin-wrap">

    {!isAuthed ? (
      <div class="login-box">
        <h1>Admin</h1>
        {authError && <p class="error">Incorrect password.</p>}
        <form method="POST">
          <input type="hidden" name="action" value="login" />
          <label for="password">Password</label>
          <input type="password" id="password" name="password" autofocus />
          <button type="submit">Sign In</button>
        </form>
      </div>
    ) : (
      <div>
        <!-- Header -->
        <div class="admin-header">
          <h1>Admin</h1>
          <form method="POST">
            <input type="hidden" name="action" value="logout" />
            <button type="submit" class="logout-btn">Log Out</button>
          </form>
        </div>

        <!-- Stats bar -->
        <div class="stats-bar">
          <div class="stat">
            <span class="stat-n">{stats.totalListings}</span>
            <span class="stat-label">Live Listings</span>
          </div>
          <div class="stat">
            <span class="stat-n{stats.pendingSubmissions > 0 ? ' alert' : ''}">{stats.pendingSubmissions}</span>
            <span class="stat-label">Pending Submissions</span>
          </div>
          <div class="stat">
            <span class="stat-n{stats.pendingClaims > 0 ? ' alert' : ''}">{stats.pendingClaims}</span>
            <span class="stat-label">Pending Claims</span>
          </div>
          <div class="stat">
            <span class="stat-n">{stats.totalSubscribers}</span>
            <span class="stat-label">Subscribers</span>
          </div>
        </div>

        <!-- Tabs -->
        <div class="tabs">
          <a href="?tab=submissions" class={`tab${tab === 'submissions' ? ' active' : ''}`}>
            Submissions {stats.pendingSubmissions > 0 && <span class="badge">{stats.pendingSubmissions}</span>}
          </a>
          <a href="?tab=claims" class={`tab${tab === 'claims' ? ' active' : ''}`}>
            Claims {stats.pendingClaims > 0 && <span class="badge">{stats.pendingClaims}</span>}
          </a>
          <a href="?tab=subscribers" class={`tab${tab === 'subscribers' ? ' active' : ''}`}>
            Subscribers
          </a>
        </div>

        <!-- Submissions tab -->
        {tab === 'submissions' && (
          <div class="tab-content">
            {submissions.length === 0 ? (
              <p class="empty">No pending submissions.</p>
            ) : (
              <div class="card-list">
                {submissions.map((s) => (
                  <div class="card">
                    <div class="card-head">
                      <div>
                        <strong>{s.name}</strong>
                        <span class="pill">{s.listing_type.replace(/_/g, ' ')}</span>
                      </div>
                      <span class="date">{new Date(s.created_at).toLocaleDateString()}</span>
                    </div>
                    <div class="card-body">
                      <p><b>Location:</b> {s.city_name}, {s.state_code}</p>
                      {s.address && <p><b>Address:</b> {s.address}</p>}
                      {s.website_url && <p><b>Website:</b> <a href={s.website_url} target="_blank" rel="noopener">{s.website_url}</a></p>}
                      {s.phone && <p><b>Phone:</b> {s.phone}</p>}
                      {s.email && <p><b>Email:</b> {s.email}</p>}
                      {s.description && <p><b>Description:</b> {s.description}</p>}
                      <p><b>Submitted by:</b> {s.submitter_name ?? 'Unknown'} ({s.submitter_email})</p>
                      {s.submitter_note && <p><b>Note:</b> {s.submitter_note}</p>}
                    </div>
                    <div class="card-actions">
                      <form method="POST">
                        <input type="hidden" name="action" value="approve" />
                        <input type="hidden" name="submission_id" value={s.id} />
                        <button class="btn green">Approve</button>
                      </form>
                      <form method="POST">
                        <input type="hidden" name="action" value="needs_info" />
                        <input type="hidden" name="submission_id" value={s.id} />
                        <button class="btn blue">Needs Info</button>
                      </form>
                      <form method="POST">
                        <input type="hidden" name="action" value="reject" />
                        <input type="hidden" name="submission_id" value={s.id} />
                        <button class="btn gray">Reject</button>
                      </form>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        <!-- Claims tab -->
        {tab === 'claims' && (
          <div class="tab-content">
            {claims.length === 0 ? (
              <p class="empty">No pending claims.</p>
            ) : (
              <div class="card-list">
                {claims.map((c) => (
                  <div class="card">
                    <div class="card-head">
                      <div>
                        <strong>{c.claimant_name}</strong> wants to claim
                        <a href={`/listing/${c.listing_slug}/`} target="_blank" rel="noopener"> {c.listing_name}</a>
                      </div>
                      <span class="date">{new Date(c.created_at).toLocaleDateString()}</span>
                    </div>
                    <div class="card-body">
                      <p><b>Email:</b> {c.claimant_email}</p>
                      {c.claimant_title && <p><b>Title:</b> {c.claimant_title}</p>}
                      {c.claimant_phone && <p><b>Phone:</b> {c.claimant_phone}</p>}
                      {c.claimant_note && <p><b>Note:</b> {c.claimant_note}</p>}
                    </div>
                    <div class="card-actions">
                      <form method="POST">
                        <input type="hidden" name="action" value="approve_claim" />
                        <input type="hidden" name="claim_id" value={c.id} />
                        <button class="btn green">Approve</button>
                      </form>
                      <form method="POST">
                        <input type="hidden" name="action" value="reject_claim" />
                        <input type="hidden" name="claim_id" value={c.id} />
                        <button class="btn gray">Reject</button>
                      </form>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        <!-- Subscribers tab -->
        {tab === 'subscribers' && (
          <div class="tab-content">
            {subscribers.length === 0 ? (
              <p class="empty">No subscribers yet.</p>
            ) : (
              <div>
                <p class="sub-count">{subscribers.length} subscriber{subscribers.length !== 1 ? 's' : ''}</p>
                <table class="sub-table">
                  <thead>
                    <tr>
                      <th>Email</th>
                      <th>Source</th>
                      <th>Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    {subscribers.map((s) => (
                      <tr>
                        <td>{s.email}</td>
                        <td>{s.source ?? 'footer'}</td>
                        <td>{new Date(s.created_at).toLocaleDateString()}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        )}
      </div>
    )}
  </div>
</Base>

<style>
  .admin-wrap { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  /* Login */
  .login-box { max-width: 360px; background: var(--sand); border: 1px solid var(--border); border-radius: 8px; padding: 2rem; }
  .login-box h1 { margin-bottom: 1.25rem; }
  .login-box label { display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.3rem; }
  .login-box input[type=password] { width: 100%; border: 1px solid var(--border); border-radius: 5px; padding: 0.55rem 0.75rem; font-size: 0.9rem; margin-bottom: 0.75rem; }
  .login-box button { background: var(--turquoise); color: #fff; border: none; padding: 0.6rem 1.5rem; border-radius: 5px; font-size: 0.9rem; cursor: pointer; font-weight: 600; }
  .error { color: #c0392b; font-size: 0.875rem; margin-bottom: 0.75rem; }

  /* Header */
  .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .admin-header h1 { margin: 0; }
  .logout-btn { background: none; border: 1px solid var(--border); padding: 0.4rem 1rem; border-radius: 5px; cursor: pointer; font-size: 0.875rem; }

  /* Stats */
  .stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
  .stat { background: var(--sand); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.25rem; }
  .stat-n { display: block; font-size: 2rem; font-weight: 800; color: var(--ink); line-height: 1; }
  .stat-n.alert { color: var(--clay); }
  .stat-label { font-size: 0.8rem; color: var(--muted); margin-top: 0.25rem; display: block; }

  /* Tabs */
  .tabs { display: flex; gap: 0; border-bottom: 2px solid var(--border); margin-bottom: 1.5rem; }
  .tab { padding: 0.6rem 1.25rem; font-size: 0.9rem; font-weight: 600; color: var(--muted); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -2px; }
  .tab:hover { color: var(--ink); text-decoration: none; }
  .tab.active { color: var(--turquoise); border-bottom-color: var(--turquoise); }
  .badge { background: var(--clay); color: #fff; font-size: 0.7rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 10px; margin-left: 0.3rem; vertical-align: middle; }

  /* Cards */
  .empty { color: var(--muted); padding: 2rem 0; }
  .card-list { display: flex; flex-direction: column; gap: 1rem; }
  .card { border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; }
  .card-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; gap: 1rem; }
  .card-head strong { font-size: 1rem; }
  .pill { display: inline-block; margin-left: 0.5rem; font-size: 0.72rem; background: var(--sand); border: 1px solid var(--border); padding: 0.1rem 0.45rem; border-radius: 3px; color: var(--muted); text-transform: capitalize; }
  .date { font-size: 0.8rem; color: var(--muted); white-space: nowrap; }
  .card-body { font-size: 0.875rem; line-height: 1.75; margin-bottom: 1rem; }
  .card-body p { margin: 0; }
  .card-body a { color: var(--turquoise); }
  .card-actions { display: flex; gap: 0.5rem; }
  .btn { border: none; padding: 0.45rem 1rem; border-radius: 5px; cursor: pointer; font-size: 0.875rem; font-weight: 600; }
  .btn.green { background: #2a7a2a; color: #fff; }
  .btn.blue { background: var(--turquoise); color: #fff; }
  .btn.gray { background: #999; color: #fff; }

  /* Subscribers table */
  .sub-count { font-size: 0.875rem; color: var(--muted); margin-bottom: 1rem; }
  .sub-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .sub-table th { text-align: left; padding: 0.5rem 0.75rem; background: var(--sand); border-bottom: 2px solid var(--border); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--muted); }
  .sub-table td { padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border); }
  .sub-table tr:last-child td { border-bottom: none; }

  @media (max-width: 600px) { .stats-bar { grid-template-columns: 1fr 1fr; } }
</style>
