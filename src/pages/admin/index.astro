---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { getPendingSubmissions, updateSubmissionStatus, createListing, getCity } from '../../lib/queries';
import sql from '../../lib/db';

const ADMIN_PASSWORD = import.meta.env.ADMIN_PASSWORD ?? 'changeme';

// Simple cookie-based auth
const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const isAuthed = cookieHeader.includes('admin_authed=1');

let authError = false;
let action = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  action = data.get('action') as string ?? '';

  if (action === 'login') {
    const pw = data.get('password') as string;
    if (pw === ADMIN_PASSWORD) {
      return new Response(null, {
        status: 302,
        headers: {
          'Set-Cookie': 'admin_authed=1; Path=/admin; HttpOnly; SameSite=Strict',
          'Location': '/admin/',
        },
      });
    } else {
      authError = true;
    }
  } else if (isAuthed) {
    const submissionId = Number(data.get('submission_id'));

    if (action === 'approve') {
      const sub = await sql`SELECT * FROM listing_submissions WHERE id = ${submissionId}`;
      if (sub[0]) {
        const s = sub[0];
        // Find or match city_id
        const cityRows = await sql`
          SELECT id FROM cities WHERE LOWER(name) = LOWER(${s.city_name}) AND state_code = ${s.state_code} LIMIT 1
        `;
        const cityId = cityRows[0]?.id ?? null;

        // Build a slug
        const slugBase = (s.name as string)
          .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        const existingSlug = await sql`SELECT slug FROM listings WHERE slug LIKE ${slugBase + '%'} ORDER BY slug DESC LIMIT 1`;
        const slug = existingSlug.length > 0 ? `${slugBase}-${Date.now()}` : slugBase;

        const created = await createListing({
          slug,
          name: s.name,
          listing_type: s.listing_type,
          state_code: s.state_code,
          city_id: cityId,
          address: s.address,
          website_url: s.website_url,
          phone: s.phone,
          email: s.email,
          description: s.description,
        });
        await updateSubmissionStatus(submissionId, 'approved', created.id);
      }
    } else if (action === 'reject') {
      await updateSubmissionStatus(submissionId, 'rejected');
    } else if (action === 'needs_info') {
      await updateSubmissionStatus(submissionId, 'needs_info');
    } else if (action === 'logout') {
      return new Response(null, {
        status: 302,
        headers: {
          'Set-Cookie': 'admin_authed=; Path=/admin; HttpOnly; Expires=Thu, 01 Jan 1970 00:00:00 GMT',
          'Location': '/admin/',
        },
      });
    }
  }
}

const submissions = isAuthed ? await getPendingSubmissions() : [];
---

<Base title="Admin | Southwest Galleries">
  <div class="container" style="padding-top:2rem;padding-bottom:3rem;max-width:900px">
    <h1>Admin Dashboard</h1>

    {!isAuthed ? (
      <div class="login-box">
        <h2>Sign In</h2>
        {authError && <p class="error">Incorrect password.</p>}
        <form method="POST">
          <input type="hidden" name="action" value="login" />
          <label for="password">Password</label>
          <input type="password" id="password" name="password" autofocus />
          <button type="submit">Sign In</button>
        </form>
      </div>
    ) : (
      <div>
        <div class="admin-header">
          <p>{submissions.length} pending submission{submissions.length !== 1 ? 's' : ''}</p>
          <form method="POST" style="display:inline">
            <input type="hidden" name="action" value="logout" />
            <button type="submit" class="logout-btn">Log Out</button>
          </form>
        </div>

        {submissions.length === 0 ? (
          <p style="color:var(--muted);padding:2rem 0">No pending submissions.</p>
        ) : (
          <div class="submissions-list">
            {submissions.map((s) => (
              <div class="submission-card">
                <div class="sub-header">
                  <div>
                    <strong>{s.name}</strong>
                    <span class="sub-type">{s.listing_type}</span>
                  </div>
                  <span class="sub-date">{new Date(s.created_at).toLocaleDateString()}</span>
                </div>
                <div class="sub-details">
                  <p><strong>Location:</strong> {s.city_name}, {s.state_code}</p>
                  {s.address && <p><strong>Address:</strong> {s.address}</p>}
                  {s.website_url && <p><strong>Website:</strong> <a href={s.website_url} target="_blank">{s.website_url}</a></p>}
                  {s.phone && <p><strong>Phone:</strong> {s.phone}</p>}
                  {s.email && <p><strong>Email:</strong> {s.email}</p>}
                  {s.description && <p><strong>Description:</strong> {s.description}</p>}
                  <p><strong>Submitted by:</strong> {s.submitter_name ?? 'Unknown'} ({s.submitter_email})</p>
                  {s.submitter_note && <p><strong>Note:</strong> {s.submitter_note}</p>}
                </div>
                <div class="sub-actions">
                  <form method="POST" style="display:inline">
                    <input type="hidden" name="action" value="approve" />
                    <input type="hidden" name="submission_id" value={s.id} />
                    <button type="submit" class="btn approve">Approve</button>
                  </form>
                  <form method="POST" style="display:inline">
                    <input type="hidden" name="action" value="needs_info" />
                    <input type="hidden" name="submission_id" value={s.id} />
                    <button type="submit" class="btn info">Needs Info</button>
                  </form>
                  <form method="POST" style="display:inline">
                    <input type="hidden" name="action" value="reject" />
                    <input type="hidden" name="submission_id" value={s.id} />
                    <button type="submit" class="btn reject">Reject</button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</Base>

<style>
  h1 { margin-bottom: 1.5rem; }
  .login-box { max-width: 360px; background: var(--sand); border: 1px solid var(--border); border-radius: 8px; padding: 2rem; }
  .login-box h2 { margin-bottom: 1rem; }
  .login-box label { display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.3rem; }
  .login-box input[type=password] { width: 100%; border: 1px solid var(--border); border-radius: 5px; padding: 0.55rem 0.75rem; font-size: 0.9rem; margin-bottom: 0.75rem; }
  .login-box button { background: var(--turquoise); color: #fff; border: none; padding: 0.6rem 1.5rem; border-radius: 5px; font-size: 0.9rem; cursor: pointer; font-weight: 600; }
  .error { color: #c0392b; font-size: 0.875rem; margin-bottom: 0.75rem; }

  .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .logout-btn { background: none; border: 1px solid var(--border); padding: 0.4rem 1rem; border-radius: 5px; cursor: pointer; font-size: 0.875rem; }

  .submissions-list { display: flex; flex-direction: column; gap: 1rem; }
  .submission-card { border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; }
  .sub-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem; }
  .sub-header strong { font-size: 1.05rem; }
  .sub-type { margin-left: 0.5rem; font-size: 0.75rem; background: var(--sand); padding: 0.15rem 0.4rem; border-radius: 3px; color: var(--muted); }
  .sub-date { font-size: 0.8rem; color: var(--muted); }
  .sub-details { font-size: 0.875rem; line-height: 1.7; margin-bottom: 1rem; }
  .sub-details p { margin: 0; }
  .sub-actions { display: flex; gap: 0.5rem; }
  .btn { border: none; padding: 0.45rem 1rem; border-radius: 5px; cursor: pointer; font-size: 0.875rem; font-weight: 600; }
  .btn.approve { background: #2a7a2a; color: #fff; }
  .btn.info { background: var(--turquoise); color: #fff; }
  .btn.reject { background: #999; color: #fff; }
</style>
