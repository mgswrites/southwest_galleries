---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getListing, createClaim } from '../../lib/queries';

const { slug } = Astro.params;
const listing = await getListing(slug!);
if (!listing) return Astro.redirect('/galleries/');

let success = false;
let errors: Record<string, string> = {};
let formData: Record<string, string> = {};

if (Astro.request.method === 'POST') {
  const raw = await Astro.request.formData();
  formData = Object.fromEntries(raw.entries()) as Record<string, string>;

  if (!formData.claimant_name?.trim()) errors.claimant_name = 'Required';
  if (!formData.claimant_email?.trim()) errors.claimant_email = 'Required';
  if (formData.claimant_email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(formData.claimant_email)) {
    errors.claimant_email = 'Invalid email address';
  }

  if (Object.keys(errors).length === 0) {
    await createClaim({
      listing_id: listing.id,
      claimant_name: formData.claimant_name.trim(),
      claimant_email: formData.claimant_email.trim(),
      claimant_title: formData.claimant_title?.trim() || undefined,
      claimant_phone: formData.claimant_phone?.trim() || undefined,
      claimant_note: formData.claimant_note?.trim() || undefined,
    });
    success = true;
  }
}
---

<Base
  title={`Claim ${listing.name} | Southwest Galleries`}
  description={`Are you the owner or manager of ${listing.name}? Claim your listing on Southwest Galleries to update your information and unlock premium features.`}
>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav
        crumbs={[
          { label: 'Home', href: '/' },
          { label: listing.state_name, href: `/galleries/${listing.state_slug}/` },
          { label: listing.city_name, href: `/galleries/${listing.state_slug}/${listing.city_slug}/` },
          { label: listing.name, href: `/listing/${slug}/` },
          { label: 'Claim Listing' },
        ]}
      />
      <h1>Claim Your Listing</h1>
      <p>Verify that you represent <strong>{listing.name}</strong> and take control of your profile.</p>
    </div>
  </div>

  <div class="container claim-layout">
    <div class="claim-main">
      {success ? (
        <div class="success-box">
          <h2>Claim Submitted!</h2>
          <p>
            Thank you — we'll verify your connection to <strong>{listing.name}</strong> and reach out to you within 2–3 business days.
            Once approved, you'll be able to update your listing information and choose a plan to unlock premium features.
          </p>
          <a href={`/listing/${slug}/`}>Return to Listing</a>
        </div>
      ) : (
        <form method="POST" class="claim-form">
          <div class="listing-preview">
            {listing.hero_image_url && (
              <img src={listing.hero_image_url} alt={listing.name} class="preview-img" />
            )}
            <div>
              <strong>{listing.name}</strong>
              <span>{[listing.city_name, listing.state_name].filter(Boolean).join(', ')}</span>
            </div>
          </div>

          <div class="claim-info">
            <h2>What Claiming Gets You</h2>
            <ul>
              <li>Update your gallery's name, address, hours, and description</li>
              <li>Add photos and your website link</li>
              <li>Respond to your gallery's profile page</li>
              <li>Upgrade to Featured or Premium for more visibility</li>
            </ul>
          </div>

          <h2>Your Information</h2>
          <p class="subtitle">We'll verify your connection to this listing before granting access.</p>

          <div class="field-row">
            <div class="field">
              <label for="claimant_name">Your Full Name <span class="req">*</span></label>
              <input type="text" id="claimant_name" name="claimant_name" value={formData.claimant_name ?? ''} required />
              {errors.claimant_name && <span class="error">{errors.claimant_name}</span>}
            </div>
            <div class="field">
              <label for="claimant_email">Your Email <span class="req">*</span></label>
              <input type="email" id="claimant_email" name="claimant_email" value={formData.claimant_email ?? ''} required />
              {errors.claimant_email && <span class="error">{errors.claimant_email}</span>}
              <span class="hint">Use your gallery's email domain if possible — it speeds up verification.</span>
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="claimant_title">Your Title / Role</label>
              <input type="text" id="claimant_title" name="claimant_title" value={formData.claimant_title ?? ''} placeholder="e.g. Owner, Director, Manager" />
            </div>
            <div class="field">
              <label for="claimant_phone">Phone (optional)</label>
              <input type="tel" id="claimant_phone" name="claimant_phone" value={formData.claimant_phone ?? ''} />
            </div>
          </div>

          <div class="field">
            <label for="claimant_note">Anything to add?</label>
            <textarea id="claimant_note" name="claimant_note" rows={3} placeholder="e.g. I'm the gallery director, you can call us at our listed number to verify">{formData.claimant_note ?? ''}</textarea>
          </div>

          <div class="form-footer">
            <button type="submit">Submit Claim</button>
            <p class="disclaimer">
              By submitting, you confirm you are authorized to represent {listing.name}. False claims will be rejected.
            </p>
          </div>
        </form>
      )}
    </div>

    <aside class="claim-sidebar">
      <div class="sidebar-card">
        <h3>How It Works</h3>
        <ol>
          <li>Submit this form with your contact information.</li>
          <li>We verify your connection to the listing (usually 1–3 business days).</li>
          <li>Once approved, you receive login access to manage your profile.</li>
          <li>Optionally upgrade your listing for more exposure and features.</li>
        </ol>
      </div>
      <div class="sidebar-card upgrade">
        <h3>Upgrade Options</h3>
        <div class="tier">
          <strong>Basic</strong>
          <span>$99/yr</span>
          <p>Enhanced profile, priority listing in city pages</p>
        </div>
        <div class="tier">
          <strong>Featured</strong>
          <span>$199/yr</span>
          <p>Featured badge, top placement, photo gallery</p>
        </div>
        <div class="tier highlight">
          <strong>Premium</strong>
          <span>$349/yr</span>
          <p>Maximum visibility, analytics, all features</p>
        </div>
        <a href={`/upgrade/${slug}/`} class="upgrade-link">View Plan Details →</a>
      </div>
    </aside>
  </div>
</Base>

<style>
  .claim-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2.5rem;
    padding-top: 2rem;
    padding-bottom: 3rem;
    align-items: start;
  }
  .listing-preview {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    background: var(--sand);
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }
  .preview-img { width: 64px; height: 64px; object-fit: cover; border-radius: 5px; }
  .listing-preview strong { display: block; font-weight: 700; }
  .listing-preview span { font-size: 0.85rem; color: var(--muted); }
  .claim-info { margin-bottom: 1.75rem; padding: 1.25rem; border: 1px solid var(--border); border-radius: 8px; }
  .claim-info h2 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.75rem; }
  .claim-info ul { padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.875rem; color: #444; }
  .claim-form h2 { font-size: 1rem; font-weight: 700; margin-bottom: 0.35rem; }
  .subtitle { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.25rem; }
  .field { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
  .field label { font-size: 0.875rem; font-weight: 600; }
  .req { color: var(--clay); }
  .field input, .field select, .field textarea {
    padding: 0.55rem 0.75rem; border: 1px solid var(--border); border-radius: 5px;
    font-size: 0.9rem; font-family: inherit; background: #fff;
  }
  .field input:focus, .field textarea:focus { outline: 2px solid var(--turquoise); border-color: transparent; }
  .hint { font-size: 0.78rem; color: var(--muted); }
  .error { font-size: 0.78rem; color: var(--clay); font-weight: 600; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-footer { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .form-footer button {
    background: var(--turquoise); color: #fff; border: none; padding: 0.75rem 2rem;
    border-radius: 6px; font-size: 0.95rem; font-weight: 700; cursor: pointer;
  }
  .form-footer button:hover { background: #0a7070; }
  .disclaimer { font-size: 0.78rem; color: var(--muted); max-width: 380px; }
  .success-box { background: var(--sand); border-radius: 8px; padding: 2.5rem; }
  .success-box h2 { font-size: 1.4rem; margin-bottom: 0.75rem; }
  .success-box p { color: var(--muted); margin-bottom: 1.5rem; line-height: 1.6; }
  .success-box a { color: var(--clay); font-weight: 600; }

  .sidebar-card { border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; margin-bottom: 1rem; }
  .sidebar-card h3 { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 1rem; }
  .sidebar-card ol { padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.65rem; font-size: 0.85rem; color: #444; line-height: 1.5; }
  .sidebar-card.upgrade { background: var(--sand); }
  .tier { padding: 0.6rem 0; border-bottom: 1px solid var(--border); display: grid; grid-template-columns: 1fr auto; align-items: start; gap: 0.25rem; }
  .tier:last-of-type { border-bottom: none; }
  .tier strong { font-size: 0.875rem; }
  .tier span { font-size: 0.85rem; font-weight: 700; color: var(--clay); }
  .tier p { font-size: 0.78rem; color: var(--muted); grid-column: 1 / -1; }
  .tier.highlight strong { color: var(--turquoise); }
  .upgrade-link { display: block; margin-top: 0.75rem; font-size: 0.85rem; font-weight: 600; color: var(--clay); }

  @media (max-width: 768px) {
    .claim-layout { grid-template-columns: 1fr; }
    .field-row { grid-template-columns: 1fr; }
  }
</style>
