---
export const prerender = true;
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found | Southwest Galleries"
  description="The page you're looking for doesn't exist. Browse Southwest Galleries to discover art galleries, museums, and cultural venues across the American Southwest."
>
  <div class="not-found">
    <div class="container">
      <h1>404</h1>
      <p class="subtitle">Page not found</p>
      <p class="body">The page you're looking for doesn't exist or may have moved.</p>
      <div class="not-found-links">
        <a href="/" class="btn-primary">Go Home</a>
        <a href="/galleries/">Browse Galleries</a>
        <a href="/guides/">Read Guides</a>
        <a href="/events/">Events</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .not-found { padding: 6rem 1.5rem; text-align: center; }
  .not-found h1 { font-size: 5rem; color: var(--clay); margin-bottom: 0.25rem; line-height: 1; }
  .subtitle { font-size: 1.4rem; font-family: 'Rye', serif; color: var(--ink); margin-bottom: 1rem; }
  .body { color: var(--muted); margin-bottom: 2.5rem; font-size: 1rem; }
  .not-found-links { display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap; align-items: center; }
  .btn-primary { background: var(--turquoise); color: #fff; padding: 0.65rem 1.75rem; border-radius: 5px; font-weight: 600; font-size: 0.95rem; }
  .btn-primary:hover { background: #0a7070; text-decoration: none; }
  .not-found-links a:not(.btn-primary) { color: var(--turquoise); font-size: 0.95rem; }
</style>
