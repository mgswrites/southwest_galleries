---
export const prerender = true;
// rebuild
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getStates, getState, getCitiesByState, getListingsByState } from '../../lib/queries';

export async function getStaticPaths() {
  const states = await getStates();
  return states.map((s) => ({ params: { state: s.slug } }));
}

const { state: stateSlug } = Astro.params;
const stateData = await getState(stateSlug!);
if (!stateData) return Astro.redirect('/galleries/');

const cities = await getCitiesByState(stateData.code);
const listings = await getListingsByState(stateData.code);
const featured = listings.filter((l) => l.tier === 'featured' || l.tier === 'premium').slice(0, 6);

const title = stateData.meta_title ?? `Art Galleries in ${stateData.name} | Southwest Galleries`;
const description = stateData.meta_description ?? `Find the best art galleries in ${stateData.name}. Browse galleries in ${cities.map((c) => c.name).slice(0, 4).join(', ')}, and more.`;

const cityNames = cities.map((c) => c.name);
const topCities = cityNames.slice(0, 4).join(', ');
const stateName = stateData.name;

const stateEditorials: Record<string, string> = {
  arizona: `Arizona's gallery scene spans from Scottsdale's gallery-lined Marshall Way and Sedona's canyon-backdrop studios to Phoenix's booming Roosevelt Row arts district and the historic artist colony of Tubac. The state is a major center for both Western American fine art and a growing contemporary scene shaped by its desert landscape and deep Indigenous artistic traditions.`,
  california: `California brings together some of the West's most dynamic gallery markets, from Los Angeles's internationally recognized contemporary art districts in Culver City and Chinatown to Palm Desert's El Paseo fine art corridor and San Diego's thriving Barrio Logan mural scene. The state's artistic output spans centuries of influence, from Spanish mission aesthetics to cutting-edge digital and conceptual art.`,
  colorado: `Colorado's art scene stretches from Denver's RiNo and Santa Fe Arts Districts — among the most vibrant in the Mountain West — to the world-class museum and gallery programs in Aspen, Vail, and Telluride. The state's dramatic mountain landscape has long drawn Plein Air painters and photographers, while Boulder and Fort Collins anchor a lively university-driven contemporary scene.`,
  nevada: `Nevada's art world extends well beyond the Las Vegas Strip: the 18b Las Vegas Arts District is a walkable neighborhood of galleries and studios just blocks from downtown, while Reno hosts the Nevada Museum of Art and a creative community energized by its proximity to the Burning Man ecosystem. Together they make Nevada one of the most surprising art destinations in the Southwest.`,
  'new-mexico': `New Mexico is the cultural heart of the American Southwest, anchored by Santa Fe's Canyon Road — the most concentrated gallery district in the United States with more than 80 galleries in a single mile — and the living Indigenous art traditions of Taos Pueblo, a UNESCO World Heritage Site. From turquoise-and-silver jewelry to bold contemporary paintings and earth-pigment ceramics, the state's art scene is as diverse as its landscape.`,
  texas: `Texas claims some of the Southwest's most dynamic art cities: San Antonio's Blue Star Arts Complex and Pearl District sit alongside world-class institutions, while Austin's East Side has become a magnet for emerging galleries and studios. Marfa, the remote outpost in the Chihuahuan Desert made famous by Donald Judd's Chinati Foundation, remains one of the most celebrated art destinations in the world.`,
  utah: `Utah's art scene is anchored by Salt Lake City's Granary District and the Utah Museum of Contemporary Art, with a growing constellation of galleries serving the state's mountain resort communities in Park City and St. George. The state's extraordinary redrock landscape — from Moab to Bryce Canyon — has inspired generations of landscape painters, Plein Air artists, and photographers who continue to define the visual identity of the American West.`,
};
const stateEditorial = stateEditorials[stateSlug] ?? `${stateName} has ${listings.length} galleries, museums, and cultural venues listed on Southwest Galleries, spanning cities including ${topCities}. Browse by city or scroll down to explore all listings.`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `What cities have art galleries in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${stateName} has art galleries in ${topCities}${cityNames.length > 4 ? `, and ${cityNames.length - 4} more cities` : ''}. The most active gallery scenes are concentrated in ${cityNames.slice(0, 2).join(' and ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `How many art galleries are in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `There are ${stateData.gallery_count || listings.length} art galleries, museums, and cultural venues listed for ${stateName} on Southwest Galleries.`,
      },
    },
    {
      '@type': 'Question',
      name: `What types of art venues can I find in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${stateName} has a variety of art venues including commercial galleries, museums, artist studios, cultural centers, and art schools, with particular strength in Western American art, Native American art, and contemporary art.`,
      },
    },
    {
      '@type': 'Question',
      name: `When is the best time to visit art galleries in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Most galleries in ${stateName} are active year-round, with peak programming during fall (September–November) and spring (March–May). Many cities host annual gallery walks and art festivals during these seasons.`,
      },
    },
  ],
};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: new URL(`/galleries/${stateSlug}/`, Astro.site).toString(),
  },
  faqSchema,
];
---

<Base {title} {description} schema={schema}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Galleries', href: '/galleries/' },
        { label: stateData.name },
      ]} />
      <h1>Art Galleries in {stateData.name}</h1>
      <p>{stateData.description ?? stateEditorial}</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    {cities.length > 0 && (
      <section class="cities-section">
        <h2>Browse by City</h2>
        <div class="cities-grid">
          {cities.map((city) => (
            <a href={`/galleries/${stateSlug}/${city.slug}/`} class="city-pill">
              {city.name}
              {city.gallery_count > 0 && <span class="count">{city.gallery_count}</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    {featured.length > 0 && (
      <section style="margin-top:2.5rem">
        <h2>Featured Galleries</h2>
        <div class="listings-grid" style="margin-top:1rem">
          {featured.map((l) => (
            <ListingCard
              slug={l.slug}
              name={l.name}
              listing_type={l.listing_type}
              tier={l.tier}
              short_description={l.short_description}
              hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood}
              city_name={l.city_name}
              city_slug={l.city_slug}
              state_slug={stateSlug}
            />
          ))}
        </div>
      </section>
    )}

    {listings.length > 0 && (
      <section style="margin-top:2.5rem">
        <h2>All Listings in {stateData.name}</h2>
        <div class="listings-grid" style="margin-top:1rem">
          {listings.map((l) => (
            <ListingCard
              slug={l.slug}
              name={l.name}
              listing_type={l.listing_type}
              tier={l.tier}
              short_description={l.short_description}
              hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood}
              city_name={l.city_name}
              city_slug={l.city_slug}
              state_slug={stateSlug}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .cities-section h2, section h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.75rem; }
  .cities-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .city-pill {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.9rem; border: 1px solid var(--border);
    border-radius: 20px; font-size: 0.875rem; color: var(--ink);
    text-decoration: none; transition: background 0.15s, border-color 0.15s;
  }
  .city-pill:hover { background: var(--sand); border-color: var(--turquoise); text-decoration: none; }
  .count { background: var(--turquoise); color: #fff; font-size: 0.7rem; font-weight: 700;
    padding: 0.1rem 0.4rem; border-radius: 10px; }
  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>
