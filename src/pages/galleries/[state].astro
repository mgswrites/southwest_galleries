---
export const prerender = true;
// rebuild
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getStates, getState, getCitiesByState, getListingsByState } from '../../lib/queries';

export async function getStaticPaths() {
  const states = await getStates();
  return states.map((s) => ({ params: { state: s.slug } }));
}

const { state: stateSlug } = Astro.params;
const stateData = await getState(stateSlug!);
if (!stateData) return Astro.redirect('/galleries/');

const cities = await getCitiesByState(stateData.code);
const listings = await getListingsByState(stateData.code);
const featured = listings.filter((l) => l.tier === 'featured' || l.tier === 'premium').slice(0, 6);

const title = stateData.meta_title ?? `Art Galleries in ${stateData.name} | Southwest Galleries`;
const description = stateData.meta_description ?? `Find the best art galleries in ${stateData.name}. Browse galleries in ${cities.map((c) => c.name).slice(0, 4).join(', ')}, and more.`;

const cityNames = cities.map((c) => c.name);
const topCities = cityNames.slice(0, 4).join(', ');
const stateName = stateData.name;

const stateEditorials: Record<string, string> = {
  arizona: `Arizona is one of the American Southwest's richest art destinations, with a gallery scene as varied as its landscape. Scottsdale's Old Town and Marshall Way corridor constitute one of the largest concentrations of fine art galleries in the United States, specializing in Western American painting, bronze sculpture, and the work of contemporary Indigenous artists. Sedona's red rock backdrop draws painters and photographers whose studios and galleries line Tlaquepaque Arts Village and the Hillside district. Phoenix's Roosevelt Row arts district anchors a growing contemporary scene, while Tubac, a Spanish colonial village south of Tucson, has been an artist colony since the 1950s. Arizona's Indigenous artistic traditions, centered in the communities of the Diné Nation, the Hopi, and the O'odham and Piipaash peoples of the Salt River, are among the most vital in North America.`,
  california: `California encompasses some of the most dynamic and diverse gallery markets in the American West. Los Angeles's contemporary art districts in Culver City, Hollywood, and Chinatown draw collectors and curators from around the world, while the city's museum infrastructure, LACMA, The Broad, and MOCA, sets a standard matched by few cities anywhere. Palm Desert's El Paseo fine art corridor brings world-class galleries to the Coachella Valley, and San Diego's Barrio Logan has emerged as one of the most vital Chicano mural and gallery scenes in the country. The state's artistic lineage runs from Spanish mission aesthetics through the California Impressionists and mid-century modernists to the conceptual and digital artists reshaping contemporary practice today.`,
  colorado: `Colorado's art scene is anchored by Denver, whose RiNo (River North) and Santa Fe Arts Districts have established the city as one of the most exciting gallery destinations in the Mountain West. The state's ski resort communities, including Aspen, Vail, Telluride, and Steamboat Springs, support world-class galleries and summer arts festivals that attract serious collectors alongside vacationers. Colorado's dramatic mountain and canyon landscapes have drawn Plein Air painters and photographers for over a century, a tradition that continues in thriving outdoor painting communities from Creede to Ouray. Boulder and Fort Collins anchor a strong university-driven contemporary scene, while Pueblo and Colorado Springs contribute distinctive industrial and regional voices to the state's rich creative fabric.`,
  nevada: `Nevada's art world extends well beyond the Las Vegas Strip into one of the most eclectic creative communities in the West. The 18b Las Vegas Arts District is a walkable neighborhood of galleries, studios, and performance spaces just blocks from downtown Fremont Street, hosting monthly First Friday events that draw thousands of visitors. The Neon Museum preserves the iconic signage of mid-century Las Vegas as art objects of the highest order. Reno hosts the Nevada Museum of Art, the only accredited art museum in the state, alongside a creative community energized by its proximity to the Black Rock Desert and the annual Burning Man festival, which has made Nevada a global touchstone for large-scale installation art and participatory creative practice.`,
  'new-mexico': `New Mexico is the cultural heart of the American Southwest and one of the most significant art destinations in the entire United States. Santa Fe's Canyon Road is the most concentrated gallery district in the country, with more than 80 galleries within a single mile selling everything from Spanish colonial devotional art to cutting-edge contemporary work. The Palace of the Governors portal is the site of the nation's oldest continually operating Indigenous art market. Taos draws artists as it has since Ernest Blumenschein and Bert Phillips arrived by wagon in 1898, with a thriving gallery scene anchored by the historic Taos Society of Artists tradition. Albuquerque's Old Town and emerging East Downtown district add contemporary energy, while the living ceramic and jewelry traditions of the Pueblo communities, including Acoma, Zuni, Santo Domingo, and beyond, represent some of the most distinctive fine craft traditions anywhere in the world.`,
  texas: `Texas is home to some of the Southwest's most dynamic and surprising art cities. Houston's museum district ranks among the finest in the country, with the Menil Collection, the Museum of Fine Arts Houston, and the Rothko Chapel constituting a world-class cluster within walking distance. San Antonio's Blue Star Arts Complex and the Pearl District support thriving gallery scenes rooted in the city's deep Mexican-American cultural heritage. Austin's East Side has emerged as the state's most exciting address for emerging galleries and artist studios. And Marfa, the remote outpost in the Chihuahuan Desert where Donald Judd established the Chinati Foundation, has become one of the most celebrated art destinations on earth, drawing collectors and art world figures from New York, London, and Tokyo to the high desert of far West Texas.`,
  utah: `Utah's art scene is anchored by Salt Lake City, where the Utah Museum of Contemporary Art, the Utah Museum of Fine Arts, and the emerging Granary District provide a strong institutional foundation for the state's creative community. Park City, internationally known for the Sundance Film Festival, supports a thriving gallery scene along its historic Main Street, with the Kimball Art Center producing programming of national significance year-round. The Springville Museum of Art holds the finest collection of Utah art anywhere, spanning two centuries of the state's creative history. Utah's extraordinary redrock landscape, from Moab and Arches to Bryce Canyon and Zion, has inspired generations of landscape painters and photographers whose work continues to define the visual identity of the American West.`,
};
const stateEditorial = stateEditorials[stateSlug] ?? `${stateName} has ${listings.length} galleries, museums, and cultural venues listed on Southwest Galleries, spanning cities including ${topCities}. Browse by city or scroll down to explore all listings.`;

const bookingLink = `https://www.anrdoezrs.net/click-101807255-17293132?url=${encodeURIComponent('https://www.booking.com/searchresults.en-us.html?ss=' + stateData.name)}`;

const stateDeepDives: Record<string, { heading: string; body: string }> = {
  arizona: {
    heading: 'Collecting Art in Arizona',
    body: `Arizona rewards the attentive collector with extraordinary range. Scottsdale's auction houses and established galleries offer access to blue-chip Western American masters, including Remington, Russell, and Moran, alongside living artists working in the tradition. Sedona's studios skew toward landscape painting and jewelry rooted in the land. Phoenix's Roosevelt Row is the place for emerging and experimental work, with First Friday events drawing thousands of visitors monthly to a neighborhood of studios, alternative spaces, and community arts organizations. Tubac's colony of working artists offers the rare experience of buying directly from the maker in a living art village. And throughout the state, Indigenous artists working in silver, turquoise, pottery, weaving, and kachina carving maintain artistic traditions of extraordinary depth and vitality. The Indigenous art markets at the Heard Museum in Phoenix and the annual Pueblo Grande Museum Artifact Show are among the most important venues for collecting Indigenous art in the Southwest.`,
  },
  california: {
    heading: "California's Art Scene Beyond Los Angeles",
    body: `While Los Angeles rightly dominates conversations about California's art world, the state's gallery culture extends far beyond the city. The Coachella Valley has cultivated a serious collector community around the El Paseo corridor in Palm Desert, where galleries representing national and international artists serve a clientele that winters in the desert and brings sophisticated taste. San Diego's gallery scene is underrated: the city's proximity to the Mexican border gives its contemporary art a distinct cross-cultural energy, and institutions like the Museum of Contemporary Art San Diego maintain a serious program with a satellite location in La Jolla. The Central Coast communities of Santa Barbara and Carmel-by-the-Sea support gallery scenes oriented toward California Impressionism and landscape painting, while the Bay Area's long tradition of experimental and conceptual art continues through galleries and nonprofits from SoMa to West Oakland.`,
  },
  colorado: {
    heading: 'The Colorado Art Trail',
    body: `Colorado's art communities are connected by the state's extraordinary landscape, and the most rewarding way to experience them is as a trail. Denver anchors the journey with its world-class museums and commercial galleries. From there, I-70 west carries visitors through the foothills into a mountain corridor studded with art destinations: Breckenridge, Vail, Aspen. Highway 50 south opens onto the San Luis Valley and the communities of Pueblo and Alamosa, where a quieter, more rooted art scene reflects the valley's deep Hispanic and Indigenous heritage. The Million Dollar Highway between Ouray and Silverton winds past historic mining towns that have reinvented themselves as artist colonies. Telluride's annual events calendar includes a bluegrass festival, film festival, and jazz festival alongside summer gallery programming that makes the box canyon town a magnet for creative people of every stripe. No state in the American West offers more diverse art experiences within driving distance of a single hub.`,
  },
  nevada: {
    heading: 'Nevada Art Beyond the Strip',
    body: `The most important thing to know about Nevada's art scene is that Las Vegas is genuinely two cities: the Strip, and everything else. The 18b Las Vegas Arts District, centered on Charleston Boulevard and Casino Center, is a real neighborhood with real studios, galleries, and a monthly First Friday event that has been running for decades. The district is named for the 18 blocks that constitute its walkable core, and it contains some of the most interesting contemporary art spaces in the Southwest. Reno's art community is smaller and less visible but deeply committed: the Nevada Museum of Art runs an ambitious program in a striking Will Bruder-designed building, and the city's proximity to Burning Man has seeded a culture of large-scale fabrication and installation that operates year-round. The annual Life is Beautiful festival in downtown Las Vegas has further embedded contemporary visual art into the city's identity, commissioning major murals and public installations that have transformed the urban streetscape.`,
  },
  'new-mexico': {
    heading: 'New Mexico: The Art State',
    body: `New Mexico has a legitimate claim to being the most art-saturated state in the American West relative to its population. Santa Fe alone has more galleries per capita than any other American city, and the city's art market, worth hundreds of millions of dollars annually, functions as a major economic engine for the region. The annual Indigenous art market on the Plaza in August is the largest and most prestigious of its kind in the world, drawing artists from hundreds of nations and collectors from every continent. The Taos art colony, established in the early 20th century, continues to produce painters and sculptors whose work commands serious prices and critical attention. Albuquerque's emerging arts districts along Central Avenue and in the Barelas and South Broadway neighborhoods bring a grittier, more urban energy to complement Santa Fe's refined collector culture. And the small communities scattered across the state, including Abiquiú, Chimayó, Truchas, and Madrid, contain working artists whose studios welcome visitors who seek them out.`,
  },
  texas: {
    heading: 'Texas Art: Scale and Ambition',
    body: `Texas does everything at scale, and its art world is no exception. The Houston Museum District is one of the finest cultural concentrations in the United States: the Menil Collection, with its extraordinary holdings of Surrealism, ancient art, and Byzantine icons, sits on a quiet residential campus that feels like a small college: intimate, unhurried, free. The Museum of Fine Arts Houston rivals any encyclopedic museum in the country. The Rothko Chapel, with its fourteen canvases by Mark Rothko commissioned specifically for the space, is among the most moving art experiences in the world. In Dallas, the Nasher Sculpture Center and the Dallas Museum of Art anchor a vibrant Uptown gallery scene. San Antonio's dual identity as a Mexican-American cultural capital and a military city produces art that engages directly with history, identity, and border experience. And Marfa, four hours from anywhere, continues to reward the pilgrimage with Judd's permanent installations at Chinati, the ongoing program at Ballroom Marfa, and a constellation of independently run galleries and project spaces that make the town one of the most concentrated art experiences in America.`,
  },
  utah: {
    heading: "Utah's Art Scene: More Than Landscape",
    body: `Utah's art identity is inseparable from its landscape: the redrock canyons, the Wasatch peaks, the high desert light. And yet the state's creative community has always been more than painters responding to scenery. The Springville Museum of Art holds a permanent collection that documents the full arc of Utah art history, from the paintings of LeConte Stewart and Lee Greene Richards through the abstract experiments of the postwar generation to the most vital contemporary practitioners. Salt Lake City's gallery scene has diversified and deepened over the past decade, with the Granary District emerging as the city's most exciting address for experimental and emerging work. Park City's Kimball Art Center produces programming of genuine national significance, and the August Kimball Arts Festival draws collectors and artists from across the country to what is otherwise known primarily as a ski resort. Utah's Indigenous communities, particularly the Diné, whose homeland extends into the state's southeastern corner, maintain artistic traditions of extraordinary depth in weaving, jewelry, and ceramics that deserve far more attention than they typically receive from mainstream art audiences.`,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `What cities have art galleries in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${stateName} has art galleries in ${topCities}${cityNames.length > 4 ? `, and ${cityNames.length - 4} more cities` : ''}. The most active gallery scenes are concentrated in ${cityNames.slice(0, 2).join(' and ')}.`,
      },
    },
    {
      '@type': 'Question',
      name: `How many art galleries are in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `There are ${stateData.gallery_count || listings.length} art galleries, museums, and cultural venues listed for ${stateName} on Southwest Galleries.`,
      },
    },
    {
      '@type': 'Question',
      name: `What types of art venues can I find in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${stateName} has a variety of art venues including commercial galleries, museums, artist studios, cultural centers, and art schools, with particular strength in Western American art, Native American art, and contemporary art.`,
      },
    },
    {
      '@type': 'Question',
      name: `When is the best time to visit art galleries in ${stateName}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Most galleries in ${stateName} are active year-round, with peak programming during fall (September–November) and spring (March–May). Many cities host annual gallery walks and art festivals during these seasons.`,
      },
    },
  ],
};

const itemListSchema = listings.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Art Galleries in ${stateData.name}`,
  numberOfItems: listings.length,
  itemListElement: listings.slice(0, 20).map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(`/listing/${(l as { slug: string }).slug}/`, Astro.site).toString(),
    name: (l as { name: string }).name,
  })),
} : null;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: new URL(`/galleries/${stateSlug}/`, Astro.site).toString(),
  },
  faqSchema,
  ...(itemListSchema ? [itemListSchema] : []),
];
---

<Base {title} {description} schema={schema}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Galleries', href: '/galleries/' },
        { label: stateData.name },
      ]} />
      <h1>Art Galleries in {stateData.name}</h1>
      <p>{stateData.description ?? stateEditorial}</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    {cities.length > 0 && (
      <section class="cities-section">
        <h2>Browse by City</h2>
        <div class="cities-grid">
          {cities.map((city) => (
            <a href={`/galleries/${stateSlug}/${city.slug}/`} class="city-pill">
              {city.name}
              {city.gallery_count > 0 && <span class="count">{city.gallery_count}</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    {featured.length > 0 && (
      <section style="margin-top:2.5rem">
        <h2>Featured Galleries</h2>
        <div class="listings-grid" style="margin-top:1rem">
          {featured.map((l) => (
            <ListingCard
              slug={l.slug}
              name={l.name}
              listing_type={l.listing_type}
              tier={l.tier}
              short_description={l.short_description}
              hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood}
              city_name={l.city_name}
              city_slug={l.city_slug}
              state_slug={stateSlug}
            />
          ))}
        </div>
      </section>
    )}

    {listings.length > 0 && (
      <section style="margin-top:2.5rem">
        <h2>All Listings in {stateData.name}</h2>
        <div class="listings-grid" style="margin-top:1rem">
          {listings.map((l) => (
            <ListingCard
              slug={l.slug}
              name={l.name}
              listing_type={l.listing_type}
              tier={l.tier}
              short_description={l.short_description}
              hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood}
              city_name={l.city_name}
              city_slug={l.city_slug}
              state_slug={stateSlug}
            />
          ))}
        </div>
      </section>
    )}

    <section class="hotel-cta">
      <div class="hotel-cta-inner">
        <div class="hotel-cta-text">
          <h2>Where to Stay in {stateData.name}</h2>
          <p>Find hotels, inns, and vacation rentals near {stateData.name}'s galleries and cultural venues.</p>
        </div>
        <div>
          <a href={bookingLink} target="_blank" rel="noopener noreferrer sponsored" class="hotel-cta-btn">
            Search Hotels on Booking.com →
          </a>
          <p class="hotel-disclosure">Affiliate link. We may earn a commission at no cost to you.</p>
        </div>
      </div>
    </section>

    {stateDeepDives[stateSlug] && (
      <section class="deep-dive">
        <h2>{stateDeepDives[stateSlug].heading}</h2>
        <p>{stateDeepDives[stateSlug].body}</p>
      </section>
    )}

    {stateSlug === 'arizona' && (
      <div class="amazon-book-cta">
        <div class="amazon-book-inner">
          <div>
            <p class="amazon-book-label">From the Founder</p>
            <p class="amazon-book-text"><em>Striking the Black Snake: Poems from Standing Rock and Other Frontlines</em> by M.G. Salazar, founder of Southwest Galleries.</p>
          </div>
          <a href="https://amzn.to/4g5I2Kf" target="_blank" rel="noopener noreferrer sponsored" class="amazon-book-btn">Get the Book →</a>
        </div>
        <p class="amazon-disclosure">As an Amazon Associate, we earn from qualifying purchases.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .cities-section h2, section h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.75rem; }
  .hotel-cta { margin-top: 3rem; background: var(--surface); border-radius: 10px; padding: 1.75rem 2rem; }
  .hotel-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .hotel-cta-text h2 { font-size: 1.2rem; font-weight: 700; color: var(--sand); margin-bottom: 0.35rem; }
  .hotel-cta-text p { font-size: 0.9rem; color: var(--surface-muted); margin: 0; line-height: 1.5; }
  .hotel-cta-btn { display: inline-block; background: #003580; color: #fff; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
  .hotel-cta-btn:hover { background: #002a6b; text-decoration: none; }
  .hotel-disclosure { font-size: 0.7rem; color: rgba(255,255,255,0.65); margin-top: 0.5rem; text-align: center; }
  .amazon-book-cta { margin-top: 2.5rem; padding: 1.25rem 1.5rem; background: #fdf8f4; border: 1px solid var(--border); border-left: 4px solid var(--clay); border-radius: 6px; }
  .amazon-book-inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; flex-wrap: wrap; }
  .amazon-book-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--clay); margin-bottom: 0.3rem; line-height: 1.2; }
  .amazon-book-text { font-size: 0.9rem; line-height: 1.5; color: var(--ink); margin: 0; }
  .amazon-book-btn { flex-shrink: 0; display: inline-block; background: var(--clay); color: #fff; padding: 0.65rem 1.25rem; border-radius: 6px; font-weight: 700; font-size: 0.875rem; text-decoration: none; white-space: nowrap; }
  .amazon-book-btn:hover { opacity: 0.88; text-decoration: none; }
  .amazon-disclosure { font-size: 0.7rem; color: #999; margin-top: 0.75rem; margin-bottom: 0; line-height: 1.4; }
  .deep-dive {
    margin-top: 3rem;
    padding: 2rem;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .deep-dive h2 { font-size: 1.3rem; margin-bottom: 1rem; }
  .deep-dive p { font-size: 0.975rem; line-height: 1.85; color: var(--muted); }
  .cities-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .city-pill {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.9rem; border: 1px solid var(--border);
    border-radius: 20px; font-size: 0.875rem; color: var(--ink);
    text-decoration: none; transition: background 0.15s, border-color 0.15s;
  }
  .city-pill:hover { background: var(--sand); border-color: var(--turquoise); text-decoration: none; }
  .count { background: var(--turquoise); color: #fff; font-size: 0.7rem; font-weight: 700;
    padding: 0.1rem 0.4rem; border-radius: 10px; }
  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>
