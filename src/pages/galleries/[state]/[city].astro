---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import BreadcrumbNav from '../../../components/BreadcrumbNav.astro';
import ListingCard from '../../../components/ListingCard.astro';
import MapView from '../../../components/MapView.astro';
import { getStates, getState, getCitiesByState, getCity, getListingsByCity, getGuidesByCity } from '../../../lib/queries';

export async function getStaticPaths() {
  const states = await getStates();
  const paths = [];
  for (const s of states) {
    const cities = await getCitiesByState(s.code);
    for (const c of cities) {
      paths.push({ params: { state: s.slug, city: c.slug } });
    }
  }
  return paths;
}

const { state: stateSlug, city: citySlug } = Astro.params;
const stateData = await getState(stateSlug!);
if (!stateData) return Astro.redirect('/galleries/');
const cityData = await getCity(stateData.code, citySlug!);
if (!cityData) return Astro.redirect(`/galleries/${stateSlug}/`);

const [listings, cityGuides] = await Promise.all([
  getListingsByCity(cityData.id),
  getGuidesByCity(cityData.id),
]);

const featuredListings = listings.filter((l) => l.tier === 'featured' || l.tier === 'premium').slice(0, 5);

const mapMarkers = listings
  .filter((l) => l.latitude && l.longitude)
  .map((l) => ({
    lat: Number(l.latitude),
    lng: Number(l.longitude),
    label: l.name,
    href: `/listing/${l.slug}/`,
  }));

const title = cityData.meta_title ?? `Art Galleries in ${cityData.name}, ${stateData.name} | Southwest Galleries`;
const description = cityData.meta_description ?? `Find the best art galleries and cultural venues in ${cityData.name}, ${stateData.name}. ${listings.length > 0 ? `${listings.length} listings.` : ''}`;

const topListings = listings.slice(0, 3).map((l) => l.name).join(', ');
const galleryWord = listings.length === 1 ? 'gallery' : 'galleries';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How many art galleries are in ${cityData.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `There are ${listings.length} art ${galleryWord} and cultural venues listed in ${cityData.name}, ${stateData.name} on Southwest Galleries.${topListings ? ` These include ${topListings}, and more.` : ''}`,
      },
    },
    {
      '@type': 'Question',
      name: `What are the best art galleries in ${cityData.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Some of the top-rated galleries in ${cityData.name}, ${stateData.name} include${topListings ? ` ${topListings}` : ' a range of galleries spanning Western American art, contemporary art, and Native American art'}. Browse the full list above for addresses, hours, and details.`,
      },
    },
    {
      '@type': 'Question',
      name: `Is there a gallery walk in ${cityData.name}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `Many cities in the Southwest host regular gallery walks. Check individual gallery websites and local arts organizations in ${cityData.name} for current schedules and opening reception events.`,
      },
    },
  ],
};

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description,
    url: new URL(`/galleries/${stateSlug}/${citySlug}/`, Astro.site).toString(),
  },
  faqSchema,
];
---

<Base {title} {description} schema={schema}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Galleries', href: '/galleries/' },
        { label: stateData.name, href: `/galleries/${stateSlug}/` },
        { label: cityData.name },
      ]} />
      <h1>Art Galleries in {cityData.name}</h1>
      {cityData.description
        ? <p>{cityData.description}</p>
        : (
          <p>
            {cityData.name} is home to {listings.length} {listings.length === 1 ? 'gallery, museum, or cultural venue' : 'galleries, museums, and cultural venues'} in {stateData.name}'s art scene.
            {topListings && ` Notable destinations include ${topListings}${listings.length > 3 ? ', and more' : ''}.`}
            {' '}Browse the listings below for addresses, hours, and directions — or use the map to plan your visit.
          </p>
        )
      }
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    {mapMarkers.length > 0 && (
      <div style="margin-bottom:2rem">
        <MapView
          markers={mapMarkers}
          centerLat={cityData.latitude ? Number(cityData.latitude) : mapMarkers[0].lat}
          centerLng={cityData.longitude ? Number(cityData.longitude) : mapMarkers[0].lng}
          zoom={13}
          height="380px"
        />
      </div>
    )}

    {featuredListings.length > 0 && (
      <section style="margin-bottom:2.5rem">
        <h2>Featured Galleries</h2>
        <div class="listings-grid" style="margin-top:1rem">
          {featuredListings.map((l) => (
            <ListingCard
              slug={l.slug}
              name={l.name}
              listing_type={l.listing_type}
              tier={l.tier}
              short_description={l.short_description}
              hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood}
              city_name={cityData.name}
              address_line1={l.address_line1}
            />
          ))}
        </div>
      </section>
    )}

    {listings.length > 0 ? (
      <section>
        {featuredListings.length > 0 && <h2>All Listings</h2>}
        <div class="listings-grid" style="margin-top:1rem">
          {listings.map((l) => (
            <ListingCard
              slug={l.slug}
              name={l.name}
              listing_type={l.listing_type}
              tier={l.tier}
              short_description={l.short_description}
              hero_image_url={l.hero_image_url}
              neighborhood={l.neighborhood}
              city_name={cityData.name}
              address_line1={l.address_line1}
            />
          ))}
        </div>
      </section>
    ) : (
      <p style="color:var(--muted);text-align:center;padding:3rem">
        No listings yet for {cityData.name}. <a href="/submit/">Submit one →</a>
      </p>
    )}

    {cityGuides.length > 0 && (
      <section class="city-guides">
        <h2>Guides for {cityData.name}</h2>
        <ul class="guide-list">
          {cityGuides.map((g) => (
            <li><a href={`/guides/${g.slug}/`}>{g.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </div>
</Base>

<style>
  .listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  section h2 { font-size: 1.2rem; font-weight: 700; }
  .city-guides { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
  .city-guides h2 { margin-bottom: 0.75rem; }
  .guide-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .guide-list li { border-left: 3px solid var(--turquoise); padding-left: 0.75rem; }
  .guide-list a { font-size: 0.9rem; color: var(--turquoise); font-weight: 500; }
  .guide-list a:hover { text-decoration: underline; }
</style>
