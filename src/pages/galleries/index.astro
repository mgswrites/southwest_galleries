---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import { getStates } from '../../lib/queries';

const states = await getStates();

const title = 'Art Galleries in the American Southwest | Southwest Galleries';
const description = 'Browse art galleries across Arizona, New Mexico, Colorado, Nevada, Utah, and beyond. Find the best galleries by state and city.';
---

<Base {title} {description}>
  <div class="page-header">
    <div class="container">
      <BreadcrumbNav crumbs={[{ label: 'Home', href: '/' }, { label: 'Galleries' }]} />
      <h1>Art Galleries in the Southwest</h1>
      <p>Discover galleries across 7 states in the American Southwest.</p>
    </div>
  </div>

  <div class="container" style="padding-top:2rem;padding-bottom:3rem">
    <div class="states-grid">
      {states.map((state) => (
        <a href={`/galleries/${state.slug}/`} class="state-card">
          <div class="state-img" style={`background-image: url('/states/${state.slug}.jpg')`}>
            <div class="state-img-overlay"></div>
          </div>
          <div class="state-info">
            <h2>{state.name}</h2>
            <p>{state.gallery_count > 0 ? `${state.gallery_count} listings` : 'Listings coming soon'}</p>
          </div>
        </a>
      ))}
    </div>
    <section class="hotel-cta">
      <div class="hotel-cta-inner">
        <div class="hotel-cta-text">
          <h2>Planning a Trip to the Southwest?</h2>
          <p>Find hotels, inns, and vacation rentals near galleries and cultural venues across all seven states.</p>
        </div>
        <div>
          <a href="https://www.anrdoezrs.net/click-101807255-17293132" target="_blank" rel="noopener noreferrer sponsored" class="hotel-cta-btn">Search Hotels on Booking.com →</a>
          <p class="hotel-disclosure">Affiliate link. We may earn a commission at no cost to you.</p>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .states-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .state-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .state-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.12); transform: translateY(-2px); text-decoration: none; }
  .state-img { position: relative; width: 100%; aspect-ratio: 16/9; background-size: cover; background-position: center; background-color: var(--sand); }
  .state-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.25) 100%); }
  .state-info { padding: 1rem; }
  .state-info h2 { font-size: 1.1rem; font-weight: 700; }
  .state-info p { font-size: 0.875rem; color: var(--muted); margin-top: 0.25rem; }
  .hotel-cta { margin-top: 3rem; background: var(--surface); border-radius: 10px; padding: 1.75rem 2rem; }
  .hotel-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .hotel-cta-text h2 { font-size: 1.2rem; font-weight: 700; color: var(--sand); margin-bottom: 0.35rem; }
  .hotel-cta-text p { font-size: 0.9rem; color: var(--surface-muted); margin: 0; line-height: 1.5; }
  .hotel-cta-btn { display: inline-block; background: #003580; color: #fff; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 700; font-size: 0.9rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; }
  .hotel-cta-btn:hover { background: #002a6b; text-decoration: none; }
  .hotel-disclosure { font-size: 0.7rem; color: rgba(255,255,255,0.65); margin-top: 0.5rem; text-align: center; }
</style>
